---
import { ArrowRight } from "lucide-astro";

interface Props {
    title: string;
    subtitle: string;
    primaryButtonText: string;
    primaryButtonLink: string;
    secondaryButtonText?: string;
    secondaryButtonLink?: string;
    variant?: "default" | "dark" | "light";
}

const {
    title,
    subtitle,
    primaryButtonText,
    primaryButtonLink,
    secondaryButtonText,
    secondaryButtonLink,
} = Astro.props;
---

<section class="cta-section ds-section">
    <div class="cta-inner ds-container">
        <h2 class="ds-h2">{title}</h2>
        <p class="ds-body-lg cta-subtitle">{subtitle}</p>
        <div class="ds-btn-group cta-buttons">
            <a href={primaryButtonLink} class="ds-btn ds-btn--primary">
                {primaryButtonText}
                <span class="ds-btn__dot">
                    <ArrowRight size={12} strokeWidth={2} />
                </span>
            </a>
            {
                secondaryButtonText && secondaryButtonLink && (
                    <a href={secondaryButtonLink} class="ds-btn ds-btn--outline">
                        {secondaryButtonText}
                        <span class="ds-btn__dot">
                            <ArrowRight size={12} strokeWidth={2} />
                        </span>
                    </a>
                )
            }
        </div>
    </div>
</section>

<style>
    .cta-section {
        border-top: 1px solid var(--border);
        text-align: center;
    }

    .cta-inner {
        max-width: 700px;
    }

    .cta-inner .ds-h2 {
        margin-bottom: var(--space-6);
    }

    .cta-subtitle {
        margin-bottom: var(--space-10);
    }

    .cta-buttons {
        justify-content: center;
    }
</style>
