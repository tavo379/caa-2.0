---
interface Props {
    title: string;
    desc: string;
    cta: string;
    lang: string;
}

const { title, desc, cta, lang } = Astro.props;
---

<section class="ds-section ds-section--border-t ds-section--border-b">
    <div class="ds-container contact-home-inner">
        <p class="ds-label">Contacto</p>
        <h2 class="ds-h2">{title}</h2>
        <p class="ds-body-lg contact-home-desc">{desc}</p>
        <a
            href={`/${lang}/${lang === "en" ? "contact" : "contacto"}`}
            class="ds-btn ds-btn--accent"
        >
            {cta}
            <span class="ds-btn__dot">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M5 12h14M12 5l7 7-7 7"/>
                </svg>
            </span>
        </a>
    </div>
</section>

<style>
    .contact-home-inner {
        max-width: 680px;
    }

    .contact-home-inner .ds-h2 {
        margin-bottom: var(--space-6);
    }

    .contact-home-desc {
        margin-bottom: var(--space-10);
    }
</style>
