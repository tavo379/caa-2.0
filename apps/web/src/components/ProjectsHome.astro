---
import { sanityClient } from "sanity:client";
import groq from "groq";
import { ArrowRight } from "lucide-astro";

interface Props {
    title: string;
    intro: string;
    viewAll: string;
    viewProject: string;
    empty: string;
    lang: string;
}

const { title, intro, viewAll, viewProject, empty, lang } = Astro.props;

const projects = await sanityClient.fetch(
    groq`
  *[_type == "project" && language == $lang] | order(system.publishedAt desc)[0...3] {
    _id,
    title,
    "slug": slug.current,
    "imageUrl": cover.asset->url,
    "tech": tech[]
  }
`,
    { lang },
);
---

<section class="ds-section ds-section--border-b">
    <div class="ds-container">
        <span class="ds-label">{title}</span>
        <p class="ds-body projects-intro">{intro}</p>

        <div class="projects-grid">
            {
                projects.length > 0 ? (
                    projects.map((project: any) => (
                        <div class="ds-project-card">
                            <div class="ds-project-card__image">
                                {project.imageUrl ? (
                                    <img
                                        src={project.imageUrl}
                                        alt={project.title}
                                    />
                                ) : (
                                    <div class="ds-project-card__placeholder">
                                        {project.title}
                                    </div>
                                )}
                            </div>
                            <div class="ds-project-card__body">
                                <p class="ds-project-card__title">
                                    {project.title}
                                </p>
                                <p class="ds-project-card__tech">
                                    {project.tech
                                        ? project.tech.join(", ")
                                        : "Desarrollo Web"}
                                </p>
                                <div class="ds-project-card__cta">
                                    <a
                                        href={`/${lang}/${lang === "en" ? "projects" : "proyectos"}/${project.slug}`}
                                        class="ds-btn ds-btn--outline ds-btn--sm"
                                    >
                                        {viewProject}
                                        <span class="ds-btn__dot">
                                            <ArrowRight size={10} strokeWidth={2} />
                                        </span>
                                    </a>
                                </div>
                            </div>
                        </div>
                    ))
                ) : (
                    <p class="empty-state ds-body">{empty}</p>
                )
            }
        </div>

        <div class="view-all-wrap">
            <a
                href={`/${lang}/${lang === "en" ? "projects" : "proyectos"}`}
                class="ds-btn ds-btn--outline"
            >
                {viewAll}
                <span class="ds-btn__dot">
                    <ArrowRight size={12} strokeWidth={2} />
                </span>
            </a>
        </div>
    </div>
</section>

<style>
    .projects-intro {
        max-width: 600px;
        margin-bottom: var(--space-12);
    }

    .projects-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: var(--space-6);
        margin-bottom: var(--space-10);
    }

    .empty-state {
        grid-column: 1 / -1;
        text-align: center;
        padding: var(--space-16) 0;
    }

    .view-all-wrap {
        text-align: center;
    }
</style>
