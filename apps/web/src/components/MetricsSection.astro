---
interface Props {
    metric1Number: string;
    metric1Label: string;
    metric2Number: string;
    metric2Label: string;
    metric3Number: string;
    metric3Label: string;
    metric4Number: string;
    metric4Label: string;
    title?: string;
}

const {
    metric1Number,
    metric1Label,
    metric2Number,
    metric2Label,
    metric3Number,
    metric3Label,
    metric4Number,
    metric4Label,
    title,
} = Astro.props;

const metrics = [
    { number: metric1Number, label: metric1Label },
    { number: metric2Number, label: metric2Label },
    { number: metric3Number, label: metric3Label },
    { number: metric4Number, label: metric4Label },
];
---

<section class="ds-section ds-section--border-b">
    <div class="ds-container">
        {title && <span class="ds-label">{title}</span>}
        <div class="ds-metrics-grid">
            {
                metrics.map((m) => (
                    <div class="ds-metric">
                        <div class="ds-metric__arrow" aria-hidden="true">↑</div>
                        <div class="ds-metric__number">{m.number}</div>
                        <div class="ds-metric__label">{m.label}</div>
                    </div>
                ))
            }
        </div>
    </div>
</section>
