---
import { ui } from "../i18n/ui";

const { lang = "es" } = Astro.props;
const t = ui[lang as keyof typeof ui];
---

<footer class="site-footer">
    <div class="footer-inner ds-container">
        <div class="footer-brand">
            <a href={`/${lang}`} class="footer-logo">
                <img src="/caa-logo.svg" alt="Cacao & Avocado" />
            </a>
            <p class="footer-tagline">
                {
                    lang === "en"
                        ? "Premium E-commerce & Web Development Agency"
                        : "Agencia Premium de Desarrollo E-commerce y Web"
                }
            </p>
        </div>

        <nav class="footer-nav">
            <a href={`/${lang}`}>{t["nav.home"]}</a>
            <a
                href={`/${lang}/${lang === "en" ? "services" : "servicios"}`}
                >{t["nav.services"]}</a
            >
            <a
                href={`/${lang}/${lang === "en" ? "projects" : "proyectos"}`}
                >{t["nav.projects"]}</a
            >
            <a
                href={lang === "en"
                    ? `/${lang}/about`
                    : `/${lang}/nosotros`}>{t["nav.about"]}</a
            >
            <a
                href={lang === "en"
                    ? `/${lang}/contact`
                    : `/${lang}/contacto`}>{t["nav.contact"]}</a
            >
        </nav>
    </div>

    <div class="footer-bottom ds-container">
        <p class="footer-copy">
            &copy; {new Date().getFullYear()} Cacao &amp; Avocado. {
                t["footer.rights"]
            }
        </p>
    </div>
</footer>

<style>
    .site-footer {
        background-color: var(--bg);
        border-top: 1px solid var(--border);
        padding: var(--space-16) 0 var(--space-8);
    }

    .footer-inner {
        display: flex;
        flex-wrap: wrap;
        justify-content: space-between;
        gap: var(--space-12);
        padding-bottom: var(--space-12);
        border-bottom: 1px solid var(--border);
        margin-bottom: var(--space-8);
    }

    .footer-logo {
        display: block;
        text-decoration: none;
        margin-bottom: var(--space-3);
    }

    .footer-logo img {
        height: 32px;
        width: auto;
    }

    .footer-tagline {
        font-size: var(--text-sm);
        color: var(--fg-muted);
        margin: 0;
    }

    .footer-nav {
        display: flex;
        flex-direction: column;
        gap: var(--space-3);
    }

    .footer-nav a {
        font-size: var(--text-sm);
        color: var(--fg-muted);
        text-decoration: none;
        transition: color var(--ease);
    }

    .footer-nav a:hover {
        color: var(--fg);
    }

    .footer-bottom {
        text-align: center;
    }

    .footer-copy {
        font-size: var(--text-xs);
        color: var(--fg-faint);
        letter-spacing: 0.04em;
        margin: 0;
    }

    @media (max-width: 640px) {
        .footer-inner {
            flex-direction: column;
        }
    }
</style>
