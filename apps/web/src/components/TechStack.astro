---
import {
    siShopify,
    siRemix,
    siReact,
    siHubspot,
    siAstro,
    siNextdotjs,
    siVercel,
    siCloudflare,
    siNodedotjs,
    siGraphql,
    siTypescript,
} from "simple-icons";

interface Props {
    title?: string;
    subtitle?: string;
}

const {
    title = "Technologies We Work With",
    subtitle =
        "Our multi-specialty approach means we can architect complete solutions, not just pieces. These are the platforms and frameworks we deploy daily.",
} = Astro.props;

const techStack = [
    { name: "Shopify Plus",  icon: siShopify    },
    { name: "React",         icon: siReact      },
    { name: "Remix",         icon: siRemix      },
    { name: "HubSpot",       icon: siHubspot    },
    { name: "Astro",         icon: siAstro      },
    { name: "Next.js",       icon: siNextdotjs  },
    { name: "Node.js",       icon: siNodedotjs  },
    { name: "TypeScript",    icon: siTypescript },
    { name: "GraphQL",       icon: siGraphql    },
    { name: "Vercel",        icon: siVercel     },
    { name: "Cloudflare",    icon: siCloudflare },
];
---

<section class="ds-section ds-section--border-b">
    <div class="ds-container">
        <div class="techstack-header">
            <span class="ds-label">{title}</span>
            <p class="ds-body techstack-desc">{subtitle}</p>
        </div>
    </div>

    <div class="carousel-wrapper">
        <div class="carousel-track">
            {[false, true, true, true].map((hidden) => (
                <div class="carousel-set" aria-hidden={hidden || undefined}>
                    {techStack.map((tech) => (
                        <div class="carousel-item">
                            <svg
                                viewBox="0 0 24 24"
                                class="tech-svg"
                                aria-label={tech.name}
                                xmlns="http://www.w3.org/2000/svg"
                            >
                                <path d={tech.icon.path} />
                            </svg>
                        </div>
                    ))}
                </div>
            ))}
        </div>
    </div>
</section>

<style>
    .techstack-header {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: var(--space-8);
        margin-bottom: var(--space-12);
        align-items: start;
    }

    .techstack-header .ds-label {
        margin-bottom: 0;
    }

    .techstack-desc {
        margin: 0;
    }

    /* ===== CAROUSEL ===== */
    .carousel-wrapper {
        overflow: hidden;
        /* Fade en los bordes */
        mask-image: linear-gradient(to right, transparent 0%, black 8%, black 92%, transparent 100%);
        -webkit-mask-image: linear-gradient(to right, transparent 0%, black 8%, black 92%, transparent 100%);
    }

    @keyframes marquee {
        from { transform: translateX(0); }
        to   { transform: translateX(calc(-1 * var(--marquee-set-w, 50%))); }
    }

    .carousel-track {
        display: flex;
        width: max-content;
        will-change: transform;
    }

    .carousel-track.is-running {
        animation: marquee 22s linear infinite;
    }

    .carousel-wrapper:hover .carousel-track {
        animation-play-state: paused;
    }

    .carousel-set {
        display: flex;
        align-items: center;
        gap: 3.5rem;
        padding-right: 3.5rem;
    }

    .carousel-item {
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .tech-svg {
        width: 2.25rem;
        height: 2.25rem;
        fill: var(--fg-icon);
        transition: fill var(--ease);
        display: block;
    }

    .carousel-item:hover .tech-svg {
        fill: var(--fg-muted);
    }

    @media (max-width: 768px) {
        .techstack-header {
            grid-template-columns: 1fr;
        }

        .tech-svg {
            width: 1.75rem;
            height: 1.75rem;
        }

        .carousel-set {
            gap: 2.5rem;
            padding-right: 2.5rem;
        }
    }
</style>

<script>
    // getBoundingClientRect gives sub-pixel accurate width — avoids the rounding
    // error that offsetWidth causes with rem-based gaps, which creates the blank gap
    // on loop. We set the exact pixel value as a CSS custom property so the keyframe
    // translateX lands on the precise same visual position as translateX(0).
    const track = document.querySelector<HTMLElement>('.carousel-track')!;
    const set1  = track.querySelector<HTMLElement>('.carousel-set')!;

    function start() {
        const w = set1.getBoundingClientRect().width;
        track.style.setProperty('--marquee-set-w', `${w}px`);
        track.classList.add('is-running');
    }

    // Double rAF: first frame commits layout, second reads accurate geometry
    requestAnimationFrame(() => requestAnimationFrame(start));

    window.addEventListener('resize', () => {
        const w = set1.getBoundingClientRect().width;
        track.style.setProperty('--marquee-set-w', `${w}px`);
    }, { passive: true });
</script>
