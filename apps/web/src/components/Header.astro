---
import { ui } from "../i18n/ui";

const { lang = "es" } = Astro.props;
const t = ui[lang as keyof typeof ui];

const navItems = [
    {
        label: t["nav.services"],
        href: `/${lang}/${lang === "en" ? "services" : "servicios"}`,
    },
    {
        label: t["nav.projects"],
        href: `/${lang}/${lang === "en" ? "projects" : "proyectos"}`,
    },
    {
        label: t["nav.about"],
        href: `/${lang}/${lang === "en" ? "about" : "nosotros"}`,
    },
    {
        label: t["nav.contact"],
        href: `/${lang}/${lang === "en" ? "contact" : "contacto"}`,
    },
];
---

<header class="site-header">
    <div class="header-inner ds-container">
        <a href={`/${lang}`} class="header-logo">
            <img src="/caa-logo.svg" alt="Cacao & Avocado" />
        </a>

        <nav class="header-nav">
            <ul>
                {
                    navItems.map((item) => (
                        <li>
                            <a href={item.href}>{item.label}</a>
                        </li>
                    ))
                }
            </ul>
        </nav>

        <div class="header-right">
            <div class="lang-toggle">
                <a href="/es" class={lang === "es" ? "active" : ""}>ES</a>
                <span>/</span>
                <a href="/en" class={lang === "en" ? "active" : ""}>EN</a>
            </div>
            <button class="mobile-toggle" aria-label="Menu">
                <span></span>
                <span></span>
                <span></span>
            </button>
        </div>
    </div>
</header>

<style>
    .site-header {
        background-color: var(--bg);
        border-bottom: 1px solid var(--border);
        padding: var(--space-4) 0;
        position: sticky;
        top: 0;
        z-index: var(--z-nav);
    }

    .header-inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: var(--space-8);
    }

    .header-logo {
        display: flex;
        align-items: center;
        flex-shrink: 0;
        text-decoration: none;
    }

    .header-logo img {
        height: 36px;
        width: auto;
    }

    .header-nav ul {
        display: flex;
        gap: var(--space-8);
        list-style: none;
        margin: 0;
        padding: 0;
    }

    .header-nav a {
        font-family: var(--font-body);
        font-size: var(--text-xs);
        font-weight: var(--font-medium);
        letter-spacing: 0.03em;
        text-transform: uppercase;
        color: var(--fg);
        text-decoration: none;
        transition: color var(--ease);
    }

    .header-nav a:hover {
        color: var(--accent);
    }

    .header-right {
        display: flex;
        align-items: center;
        gap: var(--space-6);
    }

    .lang-toggle {
        display: flex;
        align-items: center;
        gap: var(--space-2);
        font-size: var(--text-xs);
        font-weight: var(--font-semibold);
        letter-spacing: 0.06em;
    }

    .lang-toggle a {
        color: var(--fg-muted);
        text-decoration: none;
        transition: color var(--ease);
    }

    .lang-toggle a.active {
        color: var(--fg);
    }

    .lang-toggle a:hover {
        color: var(--fg);
    }

    .lang-toggle span {
        color: var(--border-strong);
    }

    .mobile-toggle {
        display: none;
        background: none;
        border: none;
        cursor: pointer;
        flex-direction: column;
        gap: var(--space-1);
        padding: var(--space-2);
    }

    .mobile-toggle span {
        display: block;
        width: 22px;
        height: 1.5px;
        background-color: var(--fg);
        transition: all var(--ease);
    }

    @media (max-width: 768px) {
        .header-nav {
            display: none;
        }

        .mobile-toggle {
            display: flex;
        }
    }
</style>
