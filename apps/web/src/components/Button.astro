---
/**
 * Button — wrapper programático sobre el sistema ds-btn.
 *
 * Variantes:
 *   primary  → borde blanco semi-transparente, fondo transparente (default)
 *   accent   → fondo naranja sólido (#E8724D)
 *   outline  → idéntico a primary (alias semántico)
 *   ghost    → sin borde, solo texto con hover sutil
 *
 * Tamaños:
 *   sm → padding reducido, text-xs
 *   md → tamaño por defecto del ds-btn (sin modificador extra)
 *   lg → padding ampliado, text-base
 *
 * Uso:
 *   <Button href="/contacto" variant="accent" size="lg">Empecemos</Button>
 *   <Button type="submit" variant="primary">Enviar</Button>
 *   <Button variant="ghost" disabled>No disponible</Button>
 */

interface Props {
    variant?: "primary" | "accent" | "outline" | "ghost";
    size?: "sm" | "lg";
    href?: string;
    type?: "button" | "submit" | "reset";
    disabled?: boolean;
    class?: string;
    [key: string]: unknown;
}

const {
    variant = "primary",
    size,
    href,
    type = "button",
    disabled = false,
    class: className = "",
    ...rest
} = Astro.props;

const Tag = href ? "a" : "button";
const componentProps = href
    ? { href, ...rest }
    : { type, disabled, ...rest };
---

<Tag
    {...componentProps}
    class:list={[
        "ds-btn",
        `ds-btn--${variant}`,
        size && `ds-btn--${size}`,
        disabled && "ds-btn--disabled",
        className,
    ]}
>
    <slot />
</Tag>
