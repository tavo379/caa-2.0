---
import { ArrowUpRight } from "lucide-astro";
import { getLocalizedPath, type Lang } from "../lib/i18n/paths";

interface Props {
    title: string;
    shopifyTitle: string;
    shopifyDesc: string;
    hubspotTitle: string;
    hubspotDesc: string;
    webTitle: string;
    webDesc: string;
    lang: Lang;
}

const {
    title,
    shopifyTitle,
    shopifyDesc,
    hubspotTitle,
    hubspotDesc,
    webTitle,
    webDesc,
    lang,
} = Astro.props;

const base = getLocalizedPath(lang, "services");

const services = [
    {
        title: shopifyTitle,
        desc:  shopifyDesc,
        href:  `${base}/ecommerce-engineering`,
    },
    {
        title: hubspotTitle,
        desc:  hubspotDesc,
        href:  `${base}/hubspot-automation`,
    },
    {
        title: webTitle,
        desc:  webDesc,
        href:  `${base}/web-development`,
    },
];
---

<section class="ds-section ds-section--border-b" id="servicios">
    <div class="ds-container">
        <span class="ds-label">{title}</span>
        <div class="ds-service-list">
            {services.map((svc) => (
                <a href={svc.href} class="ds-service-row">
                    <span class="ds-service-row__title">{svc.title}</span>
                    <span class="ds-service-row__icon" aria-hidden="true">
                        <ArrowUpRight size={20} strokeWidth={1.5} />
                    </span>
                </a>
            ))}
        </div>
    </div>
</section>
