---
import { ArrowRight } from "lucide-astro";

interface Props {
    title: string;
    desc: string;
    linkText: string;
    lang: string;
}

const { title, desc, linkText, lang } = Astro.props;
---

<section class="ds-section ds-section--border-b">
    <div class="about-home-inner ds-container">
        <h2 class="ds-h2">{title}</h2>
        <p class="ds-body-lg about-desc">{desc}</p>
        <a
            href={`/${lang}/${lang === "en" ? "about" : "nosotros"}`}
            class="ds-btn ds-btn--outline"
        >
            {linkText}
            <span class="ds-btn__dot">
                <ArrowRight size={12} strokeWidth={2} />
            </span>
        </a>
    </div>
</section>

<style>
    .about-home-inner {
        max-width: 700px;
    }

    .about-home-inner .ds-h2 {
        margin-bottom: var(--space-6);
    }

    .about-desc {
        margin-bottom: var(--space-8);
    }
</style>
