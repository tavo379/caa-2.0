---
import { ArrowRight } from "lucide-astro";

interface Props {
    title: string;
    subtitle: string;
    ctaPrimary: string;
    ctaPrimaryHref?: string;
    ctaSecondary: string;
    ctaSecondaryHref?: string;
    lang: string;
}

const {
    title,
    subtitle,
    ctaPrimary,
    ctaPrimaryHref,
    ctaSecondary,
    ctaSecondaryHref,
    lang,
} = Astro.props;

const primaryHref  = ctaPrimaryHref  ?? `/${lang}/${lang === "en" ? "contact" : "contacto"}`;
const secondaryHref = ctaSecondaryHref ?? "#servicios";
---

<section class="hero-section ds-section--border-b">
    <div class="hero-inner ds-container">
        <h1 class="ds-display hero-title" set:html={title} />
        <p class="hero-subtitle ds-body-lg">{subtitle}</p>
        <div class="ds-btn-group hero-btns">
            <a href={primaryHref} class="ds-btn ds-btn--accent">
                {ctaPrimary}
                <span class="ds-btn__dot">
                    <ArrowRight size={12} strokeWidth={2} />
                </span>
            </a>
            <a href={secondaryHref} class="ds-btn ds-btn--primary">
                {ctaSecondary}
                <span class="ds-btn__dot">
                    <ArrowRight size={12} strokeWidth={2} />
                </span>
            </a>
        </div>
    </div>
</section>

<style>
    .hero-section {
        background-color: var(--bg);
        padding: var(--space-32) 0 var(--space-24);
    }

    .hero-inner {
        max-width: 900px;
        margin-left: auto;
        margin-right: auto;
        text-align: center;
    }

    .hero-title {
        font-weight: var(--font-light);
        text-align: center;
    }

    .hero-subtitle {
        max-width: 580px;
        margin: var(--space-6) auto var(--space-10);
        text-align: center;
    }

    .hero-btns {
        justify-content: center;
        align-items: center;
    }

    @media (max-width: 768px) {
        .hero-section {
            padding: var(--space-20) 0 var(--space-16);
        }

        .hero-btns {
            flex-direction: column;
            align-items: center;
        }
    }
</style>
