---
/**
 * Design System — Cacao & Avocado
 *
 * Pagina interna de referencia del sistema de diseño.
 * Accesible en /ds (no indexada en producción).
 *
 * Documenta: tokens, tipografía, espaciado, colores y todos los componentes.
 */
import "../styles/theme.css";
import "../styles/ds.css";
import { ArrowRight } from "lucide-astro";
---

<!doctype html>
<html lang="es">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <meta name="robots" content="noindex, nofollow" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Inter:ital,opsz,wght@0,14..32,400;0,14..32,500;0,14..32,600;1,14..32,400&display=swap"
            rel="stylesheet"
        />
        <title>Design System — Cacao & Avocado</title>
    </head>

    <body>
        <!-- ============================================================
             HEADER
        ============================================================ -->
        <header class="ds-doc-header">
            <div class="ds-container" style="display:flex;align-items:center;justify-content:space-between;gap:var(--space-4)">
                <div style="display:flex;align-items:center;gap:var(--space-3)">
                    <img src="/caa-logo.svg" alt="Cacao & Avocado" style="height:28px;width:auto;" />
                    <span class="ds-doc-badge">Design System</span>
                </div>
                <a href="/es" class="ds-btn ds-btn--ghost ds-btn--sm">← Volver al sitio</a>
            </div>
        </header>

        <main>

            <!-- ============================================================
                 HERO
            ============================================================ -->
            <section class="ds-section--border-b" style="padding:5rem 0 4rem">
                <div class="ds-container">
                    <p class="ds-label">Referencia interna</p>
                    <h1 class="ds-display" style="max-width:700px">
                        Design System <span class="accent">C&A</span>
                    </h1>
                    <p class="ds-body-lg" style="max-width:560px;margin-top:var(--space-6)">
                        Tokens, tipografía, espaciado y todos los componentes del sistema de diseño de Cacao & Avocado.
                    </p>
                </div>
            </section>

            <!-- ============================================================
                 SECCIÓN: COLORES
            ============================================================ -->
            <section class="ds-section ds-section--border-b">
                <div class="ds-container">
                    <p class="ds-label">01 — Tokens</p>
                    <h2 class="ds-h2" style="margin-bottom:var(--space-12)">Colores</h2>

                    <h3 class="ds-doc-subtitle">Fondos</h3>
                    <div class="ds-doc-swatches">
                        <div class="ds-doc-swatch" style="--swatch-bg:#111111">
                            <div class="ds-doc-swatch__color"></div>
                            <div class="ds-doc-swatch__info">
                                <code>--bg</code>
                                <span>#111111</span>
                            </div>
                        </div>
                        <div class="ds-doc-swatch" style="--swatch-bg:#191919">
                            <div class="ds-doc-swatch__color"></div>
                            <div class="ds-doc-swatch__info">
                                <code>--bg-subtle</code>
                                <span>#191919</span>
                            </div>
                        </div>
                        <div class="ds-doc-swatch" style="--swatch-bg:#222222">
                            <div class="ds-doc-swatch__color"></div>
                            <div class="ds-doc-swatch__info">
                                <code>--surface</code>
                                <span>#222222</span>
                            </div>
                        </div>
                        <div class="ds-doc-swatch" style="--swatch-bg:#2A2A2A">
                            <div class="ds-doc-swatch__color"></div>
                            <div class="ds-doc-swatch__info">
                                <code>--border</code>
                                <span>#2A2A2A</span>
                            </div>
                        </div>
                        <div class="ds-doc-swatch" style="--swatch-bg:#3D3D3D">
                            <div class="ds-doc-swatch__color"></div>
                            <div class="ds-doc-swatch__info">
                                <code>--border-strong</code>
                                <span>#3D3D3D</span>
                            </div>
                        </div>
                    </div>

                    <h3 class="ds-doc-subtitle" style="margin-top:var(--space-12)">Texto</h3>
                    <div class="ds-doc-swatches">
                        <div class="ds-doc-swatch" style="--swatch-bg:#F0EDE8">
                            <div class="ds-doc-swatch__color"></div>
                            <div class="ds-doc-swatch__info">
                                <code>--fg</code>
                                <span>#F0EDE8</span>
                            </div>
                        </div>
                        <div class="ds-doc-swatch" style="--swatch-bg:#888880">
                            <div class="ds-doc-swatch__color"></div>
                            <div class="ds-doc-swatch__info">
                                <code>--fg-muted</code>
                                <span>#888880</span>
                            </div>
                        </div>
                        <div class="ds-doc-swatch" style="--swatch-bg:#444440">
                            <div class="ds-doc-swatch__color"></div>
                            <div class="ds-doc-swatch__info">
                                <code>--fg-faint</code>
                                <span>#444440</span>
                            </div>
                        </div>
                    </div>

                    <h3 class="ds-doc-subtitle" style="margin-top:var(--space-12)">Acento</h3>
                    <div class="ds-doc-swatches">
                        <div class="ds-doc-swatch" style="--swatch-bg:#E8724D">
                            <div class="ds-doc-swatch__color"></div>
                            <div class="ds-doc-swatch__info">
                                <code>--accent</code>
                                <span>#E8724D</span>
                            </div>
                        </div>
                        <div class="ds-doc-swatch" style="--swatch-bg:#F5845E">
                            <div class="ds-doc-swatch__color"></div>
                            <div class="ds-doc-swatch__info">
                                <code>--accent-hover</code>
                                <span>#F5845E</span>
                            </div>
                        </div>
                        <div class="ds-doc-swatch" style="--swatch-bg:rgba(232,114,77,0.12)">
                            <div class="ds-doc-swatch__color"></div>
                            <div class="ds-doc-swatch__info">
                                <code>--accent-muted</code>
                                <span>rgba(232,114,77,0.12)</span>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            <!-- ============================================================
                 SECCIÓN: TIPOGRAFÍA
            ============================================================ -->
            <section class="ds-section ds-section--border-b">
                <div class="ds-container">
                    <p class="ds-label">02 — Tokens</p>
                    <h2 class="ds-h2" style="margin-bottom:var(--space-12)">Tipografía</h2>

                    <h3 class="ds-doc-subtitle">Fuentes</h3>
                    <div class="ds-doc-font-row">
                        <div>
                            <code class="ds-doc-token">--font-display</code>
                            <p style="font-family:var(--font-display);font-size:var(--text-2xl);margin-top:var(--space-2)">Space Grotesk — Headings, Display</p>
                        </div>
                        <div>
                            <code class="ds-doc-token">--font-body</code>
                            <p style="font-family:var(--font-body);font-size:var(--text-2xl);margin-top:var(--space-2)">Inter — Body, UI text</p>
                        </div>
                        <div>
                            <code class="ds-doc-token">--font-mono</code>
                            <p style="font-family:var(--font-mono);font-size:var(--text-2xl);margin-top:var(--space-2)">JetBrains Mono — Code</p>
                        </div>
                    </div>

                    <h3 class="ds-doc-subtitle" style="margin-top:var(--space-12)">Escala de texto</h3>
                    <div class="ds-doc-type-scale">
                        <div class="ds-doc-type-row"><code>--text-xs · 0.75rem</code><span style="font-size:0.75rem">Texto extra pequeño — labels, badges, meta</span></div>
                        <div class="ds-doc-type-row"><code>--text-sm · 0.875rem</code><span style="font-size:0.875rem">Texto pequeño — captions, subtitles</span></div>
                        <div class="ds-doc-type-row"><code>--text-base · 1rem</code><span style="font-size:1rem">Texto base — body copy principal</span></div>
                        <div class="ds-doc-type-row"><code>--text-lg · 1.125rem</code><span style="font-size:1.125rem">Texto grande — lead paragraphs</span></div>
                        <div class="ds-doc-type-row"><code>--text-xl · 1.25rem</code><span style="font-size:1.25rem">Extra large — card titles</span></div>
                        <div class="ds-doc-type-row"><code>--text-2xl · 1.5rem</code><span style="font-size:1.5rem">2XL — section sub-headers</span></div>
                        <div class="ds-doc-type-row"><code>--text-3xl · 1.875rem</code><span style="font-size:1.875rem">3XL — section headers</span></div>
                        <div class="ds-doc-type-row"><code>--text-4xl · 2.25rem</code><span style="font-size:2.25rem">4XL — page titles</span></div>
                        <div class="ds-doc-type-row"><code>--text-5xl · 3rem</code><span style="font-size:3rem">5XL — hero titles</span></div>
                    </div>

                    <h3 class="ds-doc-subtitle" style="margin-top:var(--space-12)">Clases de tipografía</h3>
                    <div class="ds-doc-type-demo">
                        <div>
                            <code class="ds-doc-token">.ds-display</code>
                            <p class="ds-display" style="margin-top:var(--space-3)">Display Heading</p>
                        </div>
                        <div>
                            <code class="ds-doc-token">.ds-h1</code>
                            <p class="ds-h1" style="margin-top:var(--space-3)">Page Title H1</p>
                        </div>
                        <div>
                            <code class="ds-doc-token">.ds-h2</code>
                            <p class="ds-h2" style="margin-top:var(--space-3)">Section Title H2</p>
                        </div>
                        <div>
                            <code class="ds-doc-token">.ds-h3</code>
                            <p class="ds-h3" style="margin-top:var(--space-3)">Card Title H3</p>
                        </div>
                        <div>
                            <code class="ds-doc-token">.ds-body-lg</code>
                            <p class="ds-body-lg" style="margin-top:var(--space-3)">Párrafo introductorio — tamaño grande para leads.</p>
                        </div>
                        <div>
                            <code class="ds-doc-token">.ds-body</code>
                            <p class="ds-body" style="margin-top:var(--space-3)">Texto de cuerpo estándar para descripciones y contenido general.</p>
                        </div>
                        <div>
                            <code class="ds-doc-token">.ds-label</code>
                            <p class="ds-label" style="margin-top:var(--space-3)">Sección — Label</p>
                        </div>
                    </div>
                </div>
            </section>

            <!-- ============================================================
                 SECCIÓN: ESPACIADO
            ============================================================ -->
            <section class="ds-section ds-section--border-b">
                <div class="ds-container">
                    <p class="ds-label">03 — Tokens</p>
                    <h2 class="ds-h2" style="margin-bottom:var(--space-12)">Espaciado — Grid de 4px</h2>

                    <div class="ds-doc-spacing-grid">
                        {[
                            { token: "--space-1", rem: "0.25rem", px: "4px" },
                            { token: "--space-2", rem: "0.5rem",  px: "8px" },
                            { token: "--space-3", rem: "0.75rem", px: "12px" },
                            { token: "--space-4", rem: "1rem",    px: "16px" },
                            { token: "--space-5", rem: "1.25rem", px: "20px" },
                            { token: "--space-6", rem: "1.5rem",  px: "24px" },
                            { token: "--space-8", rem: "2rem",    px: "32px" },
                            { token: "--space-10","rem": "2.5rem", px: "40px" },
                            { token: "--space-12","rem": "3rem",   px: "48px" },
                            { token: "--space-16","rem": "4rem",   px: "64px" },
                            { token: "--space-20","rem": "5rem",   px: "80px" },
                            { token: "--space-24","rem": "6rem",   px: "96px" },
                            { token: "--space-32","rem": "8rem",   px: "128px" },
                        ].map(({ token, rem, px }) => (
                            <div class="ds-doc-spacing-row">
                                <code class="ds-doc-token">{token}</code>
                                <div class="ds-doc-spacing-bar" style={`width:${px};max-width:100%`}></div>
                                <span class="ds-doc-spacing-meta">{rem} · {px}</span>
                            </div>
                        ))}
                    </div>
                </div>
            </section>

            <!-- ============================================================
                 SECCIÓN: BOTONES
            ============================================================ -->
            <section class="ds-section ds-section--border-b">
                <div class="ds-container">
                    <p class="ds-label">04 — Componentes</p>
                    <h2 class="ds-h2" style="margin-bottom:var(--space-12)">Botones</h2>

                    <h3 class="ds-doc-subtitle">Variantes</h3>
                    <p class="ds-body" style="margin-bottom:var(--space-8)">Clase base: <code class="ds-doc-inline-code">.ds-btn</code> + modificador de variante.</p>
                    <div class="ds-doc-preview">
                        <div class="ds-doc-preview__stage">
                            <a class="ds-btn ds-btn--primary">
                                Primary
                                <span class="ds-btn__dot">
                                    <ArrowRight size={12} strokeWidth={2} />
                                </span>
                            </a>
                            <a class="ds-btn ds-btn--accent">
                                Accent
                                <span class="ds-btn__dot">
                                    <ArrowRight size={12} strokeWidth={2} />
                                </span>
                            </a>
                            <a class="ds-btn ds-btn--outline">
                                Outline
                                <span class="ds-btn__dot">
                                    <ArrowRight size={12} strokeWidth={2} />
                                </span>
                            </a>
                            <a class="ds-btn ds-btn--ghost">Ghost</a>
                            <a class="ds-btn ds-btn--primary ds-btn--disabled" aria-disabled="true">Disabled</a>
                        </div>
                        <div class="ds-doc-preview__code">
                            <pre><code>{`<a class="ds-btn ds-btn--primary">...</a>
<a class="ds-btn ds-btn--accent">...</a>
<a class="ds-btn ds-btn--outline">...</a>
<a class="ds-btn ds-btn--ghost">...</a>

<!-- Con componente Astro -->
<Button variant="accent" href="/contacto">Texto</Button>`}</code></pre>
                        </div>
                    </div>

                    <h3 class="ds-doc-subtitle" style="margin-top:var(--space-12)">Tamaños</h3>
                    <p class="ds-body" style="margin-bottom:var(--space-8)">Modificadores: <code class="ds-doc-inline-code">.ds-btn--sm</code> y <code class="ds-doc-inline-code">.ds-btn--lg</code>. Sin modificador = tamaño <em>md</em> (default).</p>
                    <div class="ds-doc-preview">
                        <div class="ds-doc-preview__stage" style="align-items:center">
                            <a class="ds-btn ds-btn--accent ds-btn--sm">Small</a>
                            <a class="ds-btn ds-btn--accent">Medium (default)</a>
                            <a class="ds-btn ds-btn--accent ds-btn--lg">Large</a>
                        </div>
                        <div class="ds-doc-preview__code">
                            <pre><code>{`<a class="ds-btn ds-btn--accent ds-btn--sm">Small</a>
<a class="ds-btn ds-btn--accent">Medium</a>
<a class="ds-btn ds-btn--accent ds-btn--lg">Large</a>`}</code></pre>
                        </div>
                    </div>

                    <h3 class="ds-doc-subtitle" style="margin-top:var(--space-12)">Con dot icon (estilo C&A)</h3>
                    <div class="ds-doc-preview">
                        <div class="ds-doc-preview__stage">
                            <a class="ds-btn ds-btn--primary">
                                Ver proyectos
                                <span class="ds-btn__dot">
                                    <ArrowRight size={12} strokeWidth={2} />
                                </span>
                            </a>
                            <a class="ds-btn ds-btn--accent">
                                Contactar
                                <span class="ds-btn__dot">
                                    <ArrowRight size={12} strokeWidth={2} />
                                </span>
                            </a>
                        </div>
                        <div class="ds-doc-preview__code">
                            <pre><code>{`<a class="ds-btn ds-btn--primary">
  Ver proyectos
  <span class="ds-btn__dot">
    <ArrowRight size={12} strokeWidth={2} />
  </span>
</a>`}</code></pre>
                        </div>
                    </div>
                </div>
            </section>

            <!-- ============================================================
                 SECCIÓN: CARDS
            ============================================================ -->
            <section class="ds-section ds-section--border-b">
                <div class="ds-container">
                    <p class="ds-label">05 — Componentes</p>
                    <h2 class="ds-h2" style="margin-bottom:var(--space-12)">Cards</h2>

                    <h3 class="ds-doc-subtitle">Card base</h3>
                    <div class="ds-doc-preview">
                        <div class="ds-doc-preview__stage" style="align-items:stretch">
                            <div class="ds-card" style="max-width:320px">
                                <p class="ds-label" style="margin-bottom:var(--space-2)">Categoría</p>
                                <h4 class="ds-h3" style="margin-bottom:var(--space-3)">Título de tarjeta</h4>
                                <p class="ds-body">Descripción breve del contenido de esta tarjeta de ejemplo.</p>
                            </div>
                            <a class="ds-card ds-card--link" href="#" style="max-width:320px">
                                <p class="ds-label" style="margin-bottom:var(--space-2)">Enlace</p>
                                <h4 class="ds-h3" style="margin-bottom:var(--space-3)">Card enlazable</h4>
                                <p class="ds-body">Hover activa borde acento naranja.</p>
                            </a>
                        </div>
                        <div class="ds-doc-preview__code">
                            <pre><code>{`<!-- Card estática -->
<div class="ds-card">...</div>

<!-- Card enlazada (hover naranja) -->
<a class="ds-card ds-card--link" href="...">...</a>`}</code></pre>
                        </div>
                    </div>

                    <h3 class="ds-doc-subtitle" style="margin-top:var(--space-12)">Service Card</h3>
                    <div class="ds-doc-preview">
                        <div class="ds-doc-preview__stage" style="align-items:stretch">
                            <a class="ds-service-card" href="#" style="max-width:280px">
                                <div class="ds-service-card__icon">🛒</div>
                                <h4 class="ds-service-card__title">E-Commerce</h4>
                                <p class="ds-service-card__desc">Shopify, headless y tiendas personalizadas.</p>
                                <ul class="ds-service-card__list">
                                    <li>Shopify Plus</li>
                                    <li>Headless con Hydrogen</li>
                                    <li>Migraciones de plataforma</li>
                                </ul>
                                <span class="ds-service-card__cta">Ver servicio →</span>
                            </a>
                        </div>
                        <div class="ds-doc-preview__code">
                            <pre><code>{`<a class="ds-service-card" href="...">
  <div class="ds-service-card__icon">🛒</div>
  <h4 class="ds-service-card__title">Título</h4>
  <p class="ds-service-card__desc">Descripción...</p>
  <ul class="ds-service-card__list">
    <li>Item</li>
  </ul>
  <span class="ds-service-card__cta">Ver →</span>
</a>`}</code></pre>
                        </div>
                    </div>
                </div>
            </section>

            <!-- ============================================================
                 SECCIÓN: PILLS Y BADGES
            ============================================================ -->
            <section class="ds-section ds-section--border-b">
                <div class="ds-container">
                    <p class="ds-label">06 — Componentes</p>
                    <h2 class="ds-h2" style="margin-bottom:var(--space-12)">Pills, Badges y Listas</h2>

                    <h3 class="ds-doc-subtitle">Pills — Tech tags</h3>
                    <div class="ds-doc-preview">
                        <div class="ds-doc-preview__stage">
                            <div class="ds-pill-group">
                                <span class="ds-pill">Shopify</span>
                                <span class="ds-pill">Astro</span>
                                <span class="ds-pill">TypeScript</span>
                                <span class="ds-pill">Sanity</span>
                                <span class="ds-pill">React</span>
                            </div>
                        </div>
                        <div class="ds-doc-preview__code">
                            <pre><code>{`<div class="ds-pill-group">
  <span class="ds-pill">Shopify</span>
  <span class="ds-pill">Astro</span>
</div>`}</code></pre>
                        </div>
                    </div>

                    <h3 class="ds-doc-subtitle" style="margin-top:var(--space-12)">Step badge</h3>
                    <div class="ds-doc-preview">
                        <div class="ds-doc-preview__stage" style="align-items:stretch">
                            <div class="ds-step" style="max-width:320px">
                                <span class="ds-step__number">Paso 01</span>
                                <h4 class="ds-step__title">Descubrimiento</h4>
                                <p class="ds-step__body">Auditamos tu stack actual y definimos el alcance del proyecto.</p>
                                <span class="ds-step__badge">2 semanas</span>
                            </div>
                        </div>
                        <div class="ds-doc-preview__code">
                            <pre><code>{`<div class="ds-step">
  <span class="ds-step__number">Paso 01</span>
  <h4 class="ds-step__title">Título</h4>
  <p class="ds-step__body">Descripción...</p>
  <span class="ds-step__badge">2 semanas</span>
</div>`}</code></pre>
                        </div>
                    </div>

                    <h3 class="ds-doc-subtitle" style="margin-top:var(--space-12)">Check list</h3>
                    <div class="ds-doc-preview">
                        <div class="ds-doc-preview__stage">
                            <ul class="ds-check-list" style="margin:0">
                                <li>Startups en etapa early-stage</li>
                                <li>E-commerce en crecimiento</li>
                                <li>Empresas que necesitan mover rápido</li>
                            </ul>
                        </div>
                        <div class="ds-doc-preview__code">
                            <pre><code>{`<ul class="ds-check-list">
  <li>Item con flecha naranja</li>
  <li>Otro item</li>
</ul>`}</code></pre>
                        </div>
                    </div>
                </div>
            </section>

            <!-- ============================================================
                 SECCIÓN: LAYOUT
            ============================================================ -->
            <section class="ds-section ds-section--border-b">
                <div class="ds-container">
                    <p class="ds-label">07 — Layout</p>
                    <h2 class="ds-h2" style="margin-bottom:var(--space-12)">Sistema de layout</h2>

                    <h3 class="ds-doc-subtitle">Container y secciones</h3>
                    <div class="ds-doc-token-table">
                        <div class="ds-doc-token-row"><code>.ds-container</code><span>max-width 1200px, centrado, padding horizontal</span></div>
                        <div class="ds-doc-token-row"><code>.ds-section</code><span>padding-y: <code>--section-py</code> (5rem / 3rem mobile)</span></div>
                        <div class="ds-doc-token-row"><code>.ds-section--sm</code><span>padding-y: <code>--space-12</code> (3rem)</span></div>
                        <div class="ds-doc-token-row"><code>.ds-section--subtle</code><span>background: <code>--bg-subtle</code></span></div>
                        <div class="ds-doc-token-row"><code>.ds-section--border-b</code><span>border-bottom: 1px solid <code>--border</code></span></div>
                        <div class="ds-doc-token-row"><code>.ds-section--border-t</code><span>border-top: 1px solid <code>--border</code></span></div>
                        <div class="ds-doc-token-row"><code>.ds-divider</code><span>Línea horizontal de separación</span></div>
                    </div>

                    <h3 class="ds-doc-subtitle" style="margin-top:var(--space-12)">Grids</h3>
                    <div class="ds-doc-token-table">
