---
import Layout from "../../layouts/Layout.astro";

const lang = "en";
const title =
    "Contact | Schedule a Call or Send Project Details | Cacao & Avocado";
const description =
    "Get in touch for e-commerce engineering, web development, or HubSpot automation. 24-hour response time. Based in Medellín, EST/CST compatible. English & Spanish.";
---

<Layout title={title} description={description} lang={lang}>
    <main>
        <!-- Hero -->
        <section class="ds-page-hero">
            <div class="ds-container">
                <h1 class="ds-h1">Let's Talk About Your Project</h1>
                <p class="ds-body-lg">
                    Schedule a quick call or send us your project details. We
                    typically respond within 24 hours with a technical approach
                    and ballpark estimate — no sales pitch, just engineering
                    perspective.
                </p>
            </div>
        </section>

        <!-- Contact Options -->
        <section class="ds-section ds-section--subtle ds-section--border-b">
            <div class="ds-container">
                <p class="ds-body options-lead">Choose how you'd like to connect:</p>

                <div class="contact-grid">
                    <div class="contact-option">
                        <p class="ds-h3">Schedule a Discovery Call</p>
                        <p class="ds-body">
                            30-minute video call to discuss your project, answer
                            technical questions, and explore if we're a good
                            fit. No commitment required.
                        </p>
                        <ul class="ds-check-list">
                            <li>Technical discussion (not a sales pitch)</li>
                            <li>Ballpark timeline and cost estimate</li>
                            <li>Next steps if we move forward</li>
                        </ul>
                        <a
                            href="https://calendly.com/cacaoandavocado"
                            class="ds-btn ds-btn--primary"
                            target="_blank"
                            rel="noopener noreferrer"
                        >
                            Schedule on Calendly
                            <span class="ds-btn__dot" aria-hidden="true">●</span>
                        </a>
                    </div>

                    <div class="contact-option">
                        <p class="ds-h3">Send Project Details</p>
                        <p class="ds-body">
                            Prefer to write it out? Tell us about your project
                            and we'll respond within 24 hours.
                        </p>
                        <form class="contact-form" name="contact" netlify>
                            <input
                                type="text"
                                name="name"
                                placeholder="Your name*"
                                required
                            />
                            <input
                                type="email"
                                name="email"
                                placeholder="you@company.com*"
                                required
                            />
                            <input
                                type="text"
                                name="company"
                                placeholder="Company name (optional)"
                            />
                            <select name="service" required>
                                <option value="">Service needed*</option>
                                <option>E-commerce Engineering</option>
                                <option>Web Development & CMS</option>
                                <option>HubSpot CRM & Automation</option>
                                <option>Multiple Services</option>
                                <option>Not sure yet</option>
                            </select>
                            <select name="budget" required>
                                <option value="">Budget range*</option>
                                <option>Under $10k</option>
                                <option>$10k - $25k</option>
                                <option>$25k - $50k</option>
                                <option>$50k - $100k</option>
                                <option>$100k+</option>
                                <option>Need help estimating</option>
                            </select>
                            <textarea
                                name="description"
                                rows="6"
                                placeholder="Tell us about your project: goals, challenges, timeline...*"
                                required></textarea>
                            <select name="timeline">
                                <option value="">Timeline (optional)</option>
                                <option>ASAP (1-2 weeks)</option>
                                <option>1-2 months</option>
                                <option>2-3 months</option>
                                <option>Flexible / Just exploring</option>
                            </select>
                            <button type="submit" class="ds-btn ds-btn--primary">
                                Send Project Brief
                                <span class="ds-btn__dot" aria-hidden="true">●</span>
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </section>

        <!-- Direct Contact -->
        <section class="ds-section ds-section--border-b">
            <div class="ds-container">
                <span class="ds-label">Direct Contact</span>
                <h2 class="ds-h2 info-title">Or Reach Us Directly</h2>
                <div class="info-grid">
                    <div class="info-item">
                        <p class="info-key">Email</p>
                        <p class="ds-body">hello@cacaoandavocado.co</p>
                    </div>
                    <div class="info-item">
                        <p class="info-key">Based in</p>
                        <p class="ds-body">Medellín, Colombia</p>
                    </div>
                    <div class="info-item">
                        <p class="info-key">Timezone</p>
                        <p class="ds-body">GMT-5 (EST/CST compatible)</p>
                    </div>
                    <div class="info-item">
                        <p class="info-key">Languages</p>
                        <p class="ds-body">English & Spanish</p>
                    </div>
                </div>
            </div>
        </section>

        <!-- FAQ -->
        <section class="ds-section ds-section--subtle">
            <div class="ds-container">
                <span class="ds-label">FAQ</span>
                <h2 class="ds-h2 info-title">Common Questions</h2>
                <div class="faq-list">
                    <details class="faq-item">
                        <summary>How long does a typical project take?</summary>
                        <div class="faq-body">
                            <p class="ds-body">It depends on scope, but here are averages:</p>
                            <ul class="ds-check-list">
                                <li><strong>Landing pages:</strong> 2–3 weeks</li>
                                <li><strong>HubSpot CRM implementation:</strong> 4–6 weeks</li>
                                <li><strong>Headless Shopify migration:</strong> 8–12 weeks</li>
                                <li><strong>Complete corporate site:</strong> 10–14 weeks</li>
                                <li><strong>React Native mobile app:</strong> 10–14 weeks</li>
                            </ul>
                            <p class="ds-body">We provide exact timelines in our proposal after scoping your project.</p>
                        </div>
                    </details>

                    <details class="faq-item">
                        <summary>What's your minimum project size?</summary>
                        <div class="faq-body">
                            <p class="ds-body">$5,000 for standalone projects. For ongoing work, we offer retainers starting at $2,000/month.</p>
                        </div>
                    </details>

                    <details class="faq-item">
                        <summary>Do you work with startups or only established brands?</summary>
                        <div class="faq-body">
                            <p class="ds-body">
                                Both. We work with early-stage startups (pre-seed to Series A) and established brands ($1M+ revenue). What matters is alignment: if you value code quality, transparent communication, and business-driven engineering, we're a good fit.
                            </p>
                        </div>
                    </details>

                    <details class="faq-item">
                        <summary>Can you maintain our site after launch?</summary>
                        <div class="faq-body">
                            <p class="ds-body">Yes. We offer post-launch retainers starting at $2,000/month. All projects include 30 days of support after launch (included in project cost).</p>
                        </div>
                    </details>
                </div>
            </div>
        </section>
    </main>
</Layout>

<style>
    .options-lead {
        margin-bottom: var(--space-10);
    }

    .contact-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(380px, 1fr));
        gap: var(--space-8);
    }

    .contact-option {
        display: flex;
        flex-direction: column;
        gap: var(--space-5);
    }

    .contact-option .ds-h3 {
        margin-bottom: 0;
    }

    .contact-form {
        display: flex;
        flex-direction: column;
        gap: var(--space-3);
    }

    .contact-form input,
    .contact-form select,
    .contact-form textarea {
        padding: var(--space-3) var(--space-4);
        background-color: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius-sm);
        font-size: var(--text-base);
        font-family: var(--font-body);
        color: var(--fg);
        transition: border-color var(--ease);
        width: 100%;
    }

    .contact-form input::placeholder,
    .contact-form textarea::placeholder {
        color: var(--fg-muted);
    }

    .contact-form input:focus,
    .contact-form select:focus,
    .contact-form textarea:focus {
        outline: none;
        border-color: var(--border-strong);
    }

    .contact-form select option {
        background-color: var(--surface);
        color: var(--fg);
    }

    .contact-form textarea {
        resize: vertical;
        min-height: 120px;
    }

    .info-title {
        margin-bottom: var(--space-10);
    }

    .info-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: var(--space-8);
    }

    .info-key {
        font-family: var(--font-display);
        font-size: var(--text-sm);
        font-weight: var(--font-semibold);
        color: var(--fg-muted);
        text-transform: uppercase;
        letter-spacing: 0.08em;
        margin-bottom: var(--space-1);
    }

    .faq-list {
        max-width: 800px;
        display: flex;
        flex-direction: column;
        border-top: 1px solid var(--border);
    }

    .faq-item {
        border-bottom: 1px solid var(--border);
        cursor: pointer;
    }

    .faq-item summary {
        font-family: var(--font-display);
        font-size: var(--text-lg);
        font-weight: var(--font-semibold);
        color: var(--fg);
        list-style: none;
        padding: var(--space-5) 0;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: var(--space-4);
    }

    .faq-item summary::after {
        content: "+";
        color: var(--accent);
        font-size: var(--text-xl);
        flex-shrink: 0;
    }

    .faq-item[open] summary::after {
        content: "−";
    }

    .faq-body {
        padding-bottom: var(--space-5);
        display: flex;
        flex-direction: column;
        gap: var(--space-3);
    }

    @media (max-width: 768px) {
        .contact-grid {
            grid-template-columns: 1fr;
        }
    }
</style>
