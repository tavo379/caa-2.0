---
import Layout from "../../layouts/Layout.astro";
import CTABlock from "../../components/CTABlock.astro";

const lang = "en";
const title = "About Cacao & Avocado | Premium Web Agency in Medellín";
const description =
    "Boutique web and e-commerce agency based in Medellín, Colombia. 11+ years of senior engineering experience, working with brands in Colombia and the United States.";
---

<Layout title={title} description={description} lang={lang}>
    <main>
        <!-- Hero -->
        <section class="ds-page-hero">
            <div class="ds-container">
                <h1 class="ds-h1">
                    A Premium Web &amp; E-commerce Agency Based in Medellín
                </h1>
                <p class="ds-body-lg">
                    Cacao &amp; Avocado is a boutique development agency
                    specializing in Shopify, web development, and HubSpot
                    integrations. We work with brands in Colombia and the United
                    States that want senior-level engineering without large-agency
                    overhead.
                </p>
            </div>
        </section>

        <!-- Story -->
        <section class="ds-section ds-section--subtle ds-section--border-b">
            <div class="ds-container">
                <span class="ds-label">Our Story</span>
                <h2 class="ds-h2 section-title">Where We Come From</h2>
                <div class="ds-prose">
                    <p>
                        Our team's foundation is 11+ years of senior frontend
                        engineering at top-tier technology consultancies —
                        including Globant, Zemoga, and BairesDev — where we
                        contributed to large-scale digital projects for companies
                        including Disney, Walmart, Sony, and Google.
                    </p>
                    <p>
                        We built Cacao &amp; Avocado because we saw a clear gap:
                        brands in Colombia and the US wanted the quality of
                        enterprise-level engineering, but the agencies available
                        were either too large and expensive, or too junior and
                        unreliable. We exist in that space — boutique size,
                        senior quality, direct communication.
                    </p>
                    <p>
                        The name? Cacao and avocado — two of Colombia's finest
                        exports. We like to think our work is the same: crafted
                        with care, built to last, genuinely useful.
                    </p>
                </div>
            </div>
        </section>

        <!-- How We Work -->
        <section class="ds-section ds-section--border-b">
            <div class="ds-container">
                <span class="ds-label">Our Approach</span>
                <h2 class="ds-h2 section-title">How We Work</h2>
                <div class="ds-grid-2">
                    <div class="ds-principle">
                        <p class="ds-principle__title">
                            Senior engineering on every project
                        </p>
                        <p class="ds-principle__body">
                            Every build is handled by senior-level developers.
                            We don't staff projects with juniors to protect
                            margins — quality is consistent regardless of project
                            size.
                        </p>
                    </div>
                    <div class="ds-principle">
                        <p class="ds-principle__title">
                            Direct communication, no layers
                        </p>
                        <p class="ds-principle__body">
                            No account managers translating between you and the
                            team. When you have a question or a decision to make,
                            you talk directly to the people building your project.
                        </p>
                    </div>
                    <div class="ds-principle">
                        <p class="ds-principle__title">Fixed scope, fixed price</p>
                        <p class="ds-principle__body">
                            We scope every project in detail before we start. You
                            know exactly what you're paying for and when it ships.
                            Scope changes are discussed openly — never added to an
                            invoice without your approval.
                        </p>
                    </div>
                    <div class="ds-principle">
                        <p class="ds-principle__title">
                            Performance is non-negotiable
                        </p>
                        <p class="ds-principle__body">
                            Every site we deliver targets 85+ Lighthouse scores
                            and sub-2-second load times. Fast sites rank better,
                            convert better, and retain visitors better.
                        </p>
                    </div>
                    <div class="ds-principle">
                        <p class="ds-principle__title">
                            Clean, maintainable code
                        </p>
                        <p class="ds-principle__body">
                            We write code the next developer can understand and
                            build on. Every project includes documentation and a
                            handoff session.
                        </p>
                    </div>
                </div>
            </div>
        </section>

        <!-- Who We Work With -->
        <section class="ds-section ds-section--subtle ds-section--border-b">
            <div class="ds-container who-inner">
                <span class="ds-label">Fit</span>
                <h2 class="ds-h2 section-title">Who We Work Best With</h2>
                <p class="ds-body-lg">We work well with brands that:</p>
                <ul class="ds-check-list">
                    <li>Want quality engineering, not the cheapest option</li>
                    <li>
                        Value direct communication over polished presentations
                    </li>
                    <li>
                        Are ready to invest in a digital presence that performs
                    </li>
                    <li>
                        Need a team that understands both the Colombian and US
                        markets
                    </li>
                </ul>
                <p class="ds-body not-fit-note">
                    We're probably not the right fit if you need a $500 website,
                    or if you need 10 people on every call.
                </p>
            </div>
        </section>

        <CTABlock
            title="Let's Talk"
            subtitle="30 minutes. We'll understand your project, give you honest feedback on the technical approach, and tell you what it would take to build it right."
            primaryButtonText="Schedule a Call"
            primaryButtonLink={`/${lang}/contact`}
            secondaryButtonText="Email Us → hello@cacaoandavocado.co"
            secondaryButtonLink="mailto:hello@cacaoandavocado.co"
        />
    </main>
</Layout>

<style>
    .section-title {
        margin-bottom: var(--space-10);
    }

    .who-inner {
        max-width: 800px;
    }

    .not-fit-note {
        margin-top: var(--space-6);
        font-style: italic;
    }
</style>
