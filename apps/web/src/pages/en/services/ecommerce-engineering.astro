---
import Layout from "../../../layouts/Layout.astro";
import CTABlock from "../../../components/CTABlock.astro";

const lang = "en";
const title =
    "E-commerce Engineering | Headless Shopify, Checkout Optimization & Mobile Apps | Cacao & Avocado";
const description =
    "Headless Shopify development, checkout extensibility migrations, React Native mobile apps, and CRO. E-commerce engineering for high-growth DTC brands. 85+ Lighthouse scores, 40% checkout improvements.";
---

<Layout title={title} description={description} lang={lang}>
    <main>
        <!-- Hero -->
        <section class="ds-page-hero">
            <div class="ds-container">
                <h1 class="ds-h1">E-commerce Engineering That Scales Revenue</h1>
                <p class="ds-body-lg">
                    We build and optimize high-performance Shopify Plus
                    infrastructure for brands doing $1M+ monthly. From headless
                    migrations to checkout extensibility and React Native mobile
                    apps, we combine commerce expertise with senior-level
                    engineering.
                </p>
                <p class="ds-body metrics-line">
                    50+ stores optimized · $150M+ GMV managed · 85+ avg Lighthouse score
                </p>
                <div class="ds-btn-group">
                    <a href={`/${lang}/contact`} class="ds-btn ds-btn--primary">
                        Schedule Technical Consultation
                        <span class="ds-btn__dot" aria-hidden="true">●</span>
                    </a>
                    <a href={`/${lang}/projects`} class="ds-btn ds-btn--outline">
                        View Case Studies
                        <span class="ds-btn__dot" aria-hidden="true">→</span>
                    </a>
                </div>
            </div>
        </section>

        <!-- Services Overview -->
        <section class="ds-section ds-section--subtle ds-section--border-b">
            <div class="ds-container">
                <span class="ds-label">What We Build</span>
                <h2 class="ds-h2 section-title">
                    Four core e-commerce engineering services. Choose one, or combine them for a complete commerce transformation.
                </h2>
            </div>
        </section>

        <!-- Service 1: Headless -->
        <section class="ds-section ds-section--border-b">
            <div class="ds-container service-block">
                <h3 class="ds-h3 service-title">Headless Shopify Architecture</h3>
                <div class="service-body">
                    <div class="service-subsection">
                        <p class="subsection-label">What it is</p>
                        <p class="ds-body">
                            Custom storefronts built with Hydrogen, Remix, or
                            Next.js, powered by Shopify's Storefront API.
                            Complete design freedom, sub-2-second load times,
                            and enterprise-grade performance. We handle the full
                            migration: data, SEO preservation, checkout
                            integration, and analytics setup.
                        </p>
                    </div>
                    <div class="service-subsection">
                        <p class="subsection-label">Ideal for</p>
                        <ul class="ds-check-list">
                            <li>Brands outgrowing Shopify themes ($500K+ monthly revenue)</li>
                            <li>Companies needing custom UX (subscriptions, B2B, complex catalogs)</li>
                            <li>Teams wanting to own their front-end without Shopify's Liquid limitations</li>
                            <li>International brands requiring multi-language, multi-currency storefronts</li>
                        </ul>
                    </div>
                    <div class="service-subsection">
                        <p class="subsection-label">Process</p>
                        <ul class="ds-check-list">
                            <li><strong>Phase 1:</strong> Architecture design and API setup (1–2 weeks)</li>
                            <li><strong>Phase 2:</strong> Component library and core pages (3–4 weeks)</li>
                            <li><strong>Phase 3:</strong> Product catalog, cart, checkout integration (2–3 weeks)</li>
                            <li><strong>Phase 4:</strong> Testing, SEO migration, launch (1–2 weeks)</li>
                        </ul>
                    </div>
                    <div class="ds-pill-group">
                        <span class="ds-pill">Hydrogen</span>
                        <span class="ds-pill">Remix</span>
                        <span class="ds-pill">Next.js</span>
                        <span class="ds-pill">Storefront API</span>
                        <span class="ds-pill">GraphQL</span>
                        <span class="ds-pill">Oxygen</span>
                        <span class="ds-pill">Vercel</span>
                    </div>
                    <div class="pricing-box">
                        <div class="pricing-item">
                            <span class="pricing-label">Timeline</span>
                            <span class="pricing-value">8–12 weeks</span>
                        </div>
                        <div class="pricing-item">
                            <span class="pricing-label">Investment</span>
                            <span class="pricing-value">$30,000 – $60,000</span>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Service 2: Checkout -->
        <section class="ds-section ds-section--subtle ds-section--border-b">
            <div class="ds-container service-block">
                <h3 class="ds-h3 service-title">Checkout Extensibility & Optimization</h3>
                <div class="service-body">
                    <div class="service-subsection">
                        <p class="subsection-label">What it is</p>
                        <p class="ds-body">
                            Migration from checkout.liquid to Shopify's new
                            Checkout Extensibility framework. Add custom fields,
                            upsells, trust badges, and shipping logic directly
                            in checkout — without compromising performance. We
                            audit your current checkout, identify conversion
                            leaks, and rebuild using native extensions and
                            Functions API.
                        </p>
                    </div>
                    <div class="service-subsection">
                        <p class="subsection-label">Ideal for</p>
                        <ul class="ds-check-list">
                            <li>Stores losing sales to slow or cluttered checkouts</li>
                            <li>Brands needing custom checkout logic (gift options, B2B fields, subscriptions)</li>
                            <li>Companies with checkout.liquid customizations that need modernization</li>
                            <li>Teams wanting faster checkouts without third-party scripts</li>
                        </ul>
                    </div>
                    <div class="ds-pill-group">
                        <span class="ds-pill">Checkout UI Extensions</span>
                        <span class="ds-pill">Shopify Functions</span>
                        <span class="ds-pill">React</span>
                        <span class="ds-pill">TypeScript</span>
                        <span class="ds-pill">GraphQL</span>
                    </div>
                    <div class="pricing-box">
                        <div class="pricing-item">
                            <span class="pricing-label">Timeline</span>
                            <span class="pricing-value">4–6 weeks</span>
                        </div>
                        <div class="pricing-item">
                            <span class="pricing-label">Investment</span>
                            <span class="pricing-value">$12,000 – $25,000</span>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Service 3: React Native -->
        <section class="ds-section ds-section--border-b">
            <div class="ds-container service-block">
                <h3 class="ds-h3 service-title">React Native Mobile Commerce Apps</h3>
                <div class="service-body">
                    <div class="service-subsection">
                        <p class="subsection-label">What it is</p>
                        <p class="ds-body">
                            Native iOS and Android apps with full Shopify
                            integration: product browsing, cart, checkout
                            (Shopify native or custom), order tracking, and push
                            notifications. Built with React Native for code
                            sharing and faster development. Perfect for brands
                            wanting app-exclusive products, loyalty programs, or
                            superior mobile UX.
                        </p>
                    </div>
                    <div class="service-subsection">
                        <p class="subsection-label">Ideal for</p>
                        <ul class="ds-check-list">
                            <li>DTC brands with high mobile traffic (60%+ of sales)</li>
                            <li>Companies launching loyalty or subscription programs</li>
                            <li>Brands wanting app-exclusive launches or early access</li>
                            <li>Teams needing offline browsing or AR/VR product views</li>
                        </ul>
                    </div>
                    <div class="ds-pill-group">
                        <span class="ds-pill">React Native</span>
                        <span class="ds-pill">Shopify Mobile Buy SDK</span>
                        <span class="ds-pill">Storefront API</span>
                        <span class="ds-pill">Firebase</span>
                        <span class="ds-pill">Push Notifications</span>
                    </div>
                    <div class="pricing-box">
                        <div class="pricing-item">
                            <span class="pricing-label">Timeline</span>
                            <span class="pricing-value">10–14 weeks</span>
                        </div>
                        <div class="pricing-item">
                            <span class="pricing-label">Investment</span>
                            <span class="pricing-value">$40,000 – $75,000</span>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Service 4: CRO -->
        <section class="ds-section ds-section--subtle ds-section--border-b">
            <div class="ds-container service-block">
                <h3 class="ds-h3 service-title">Performance & Conversion Rate Optimization</h3>
                <div class="service-body">
                    <div class="service-subsection">
                        <p class="subsection-label">What it is</p>
                        <p class="ds-body">
                            Technical CRO focused on speed, Core Web Vitals, and
                            conversion funnel optimization. We audit your
                            store's performance, identify bottlenecks (slow
                            scripts, render-blocking resources, heavy images),
                            and implement fixes. Combined with conversion
                            analysis: heatmaps, session recordings, and A/B
                            testing.
                        </p>
                    </div>
                    <div class="service-subsection">
                        <p class="subsection-label">Ideal for</p>
                        <ul class="ds-check-list">
                            <li>Stores with Lighthouse scores below 70</li>
                            <li>High-traffic sites with slow load times (3+ seconds)</li>
                            <li>Brands with high bounce rates on mobile</li>
                            <li>Teams launching paid ads and needing better landing page performance</li>
                        </ul>
                    </div>
                    <div class="ds-pill-group">
                        <span class="ds-pill">Lighthouse</span>
                        <span class="ds-pill">WebPageTest</span>
                        <span class="ds-pill">Google Analytics 4</span>
                        <span class="ds-pill">Hotjar</span>
                        <span class="ds-pill">Optimizely</span>
                        <span class="ds-pill">Cloudflare</span>
                    </div>
                    <div class="pricing-box">
                        <div class="pricing-item">
                            <span class="pricing-label">Timeline</span>
                            <span class="pricing-value">4–6 weeks</span>
                        </div>
                        <div class="pricing-item">
                            <span class="pricing-label">Investment</span>
                            <span class="pricing-value">$8,000 – $18,000</span>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <CTABlock
            title="Ready to Scale Your Store's Infrastructure?"
            subtitle="Let's start with a free technical audit. We'll analyze your current setup, identify optimization opportunities, and provide a roadmap with estimated ROI."
            primaryButtonText="Schedule Free Audit"
            primaryButtonLink={`/${lang}/contact`}
            secondaryButtonText="View Case Studies"
            secondaryButtonLink={`/${lang}/projects`}
        />
    </main>
</Layout>

<style>
    .metrics-line {
        color: var(--fg-muted);
        margin-bottom: var(--space-8);
    }

    .section-title {
        margin-bottom: 0;
        font-weight: var(--font-normal);
        color: var(--fg-muted);
        font-size: var(--text-lg);
        font-family: var(--font-body);
        max-width: 700px;
    }

    .service-block {
        max-width: 900px;
    }

    .service-title {
        margin-bottom: var(--space-8);
        padding-bottom: var(--space-5);
        border-bottom: 1px solid var(--border);
    }

    .service-body {
        display: flex;
        flex-direction: column;
        gap: var(--space-6);
    }

    .service-subsection {
        display: flex;
        flex-direction: column;
        gap: var(--space-3);
    }

    .subsection-label {
        font-family: var(--font-display);
        font-size: var(--text-sm);
        font-weight: var(--font-semibold);
        color: var(--fg-muted);
        text-transform: uppercase;
        letter-spacing: 0.08em;
    }

    .pricing-box {
        display: flex;
        gap: var(--space-10);
        padding: var(--space-5) var(--space-6);
        border: 1px solid var(--border);
        border-left: 3px solid var(--accent);
        border-radius: var(--radius-sm);
        background-color: var(--surface);
        margin-top: var(--space-2);
    }

    .pricing-item {
        display: flex;
        flex-direction: column;
        gap: var(--space-1);
    }

    .pricing-label {
        font-size: var(--text-xs);
        color: var(--fg-muted);
        text-transform: uppercase;
        letter-spacing: 0.08em;
        font-family: var(--font-display);
    }

    .pricing-value {
        font-family: var(--font-display);
        font-size: var(--text-xl);
        font-weight: var(--font-bold);
        color: var(--fg);
    }

    @media (max-width: 768px) {
        .pricing-box {
            flex-direction: column;
            gap: var(--space-5);
        }
    }
</style>
