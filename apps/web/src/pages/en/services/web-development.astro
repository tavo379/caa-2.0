---
import Layout from "../../../layouts/Layout.astro";
import CTABlock from "../../../components/CTABlock.astro";

const lang = "en";
const title =
    "Web Development & CMS | HubSpot CMS, Landing Pages & Corporate Sites | Cacao & Avocado";
const description =
    "HubSpot CMS development, high-converting landing pages, and corporate websites. Performance-first web development with 85+ Lighthouse scores. Modern stack, clean code, fast delivery.";
---

<Layout title={title} description={description} lang={lang}>
    <main>
        <!-- Hero -->
        <section class="ds-page-hero">
            <div class="ds-container">
                <h1 class="ds-h1">Web Development Built For Performance & Conversion</h1>
                <p class="ds-body-lg">
                    We build corporate websites, landing pages, and HubSpot CMS
                    sites that convert. Every site ships with 85+ Lighthouse
                    scores, semantic SEO, and content workflows that scale with
                    your team.
                </p>
                <p class="ds-body metrics-line">
                    85+ avg Lighthouse score · &lt;2s load time · 100+ pages launched
                </p>
                <div class="ds-btn-group">
                    <a href={`/${lang}/contact`} class="ds-btn ds-btn--primary">
                        Schedule Consultation
                        <span class="ds-btn__dot" aria-hidden="true">●</span>
                    </a>
                    <a href={`/${lang}/projects`} class="ds-btn ds-btn--outline">
                        View Our Work
                        <span class="ds-btn__dot" aria-hidden="true">→</span>
                    </a>
                </div>
            </div>
        </section>

        <!-- Overview -->
        <section class="ds-section ds-section--subtle ds-section--border-b">
            <div class="ds-container">
                <span class="ds-label">What We Build</span>
                <h2 class="ds-h2 section-title">
                    Three core web development services. Built for performance, designed for conversion, optimized for search.
                </h2>
            </div>
        </section>

        <!-- Service 1: HubSpot CMS -->
        <section class="ds-section ds-section--border-b">
            <div class="ds-container service-block">
                <h3 class="ds-h3 service-title">HubSpot CMS Development</h3>
                <div class="service-body">
                    <div class="service-subsection">
                        <p class="subsection-label">What it is</p>
                        <p class="ds-body">
                            Custom HubSpot CMS websites with drag-and-drop
                            editing for your marketing team. We build modular
                            themes, custom modules, and integrated forms/CTAs so
                            your team can create landing pages and content
                            without developer dependencies.
                        </p>
                    </div>
                    <div class="service-subsection">
                        <p class="subsection-label">Ideal for</p>
                        <ul class="ds-check-list">
                            <li>Companies already using HubSpot for CRM/marketing</li>
                            <li>Marketing teams needing content agility (launch pages quickly)</li>
                            <li>Brands wanting unified analytics (website + CRM data in one place)</li>
                            <li>B2B companies needing lead capture and attribution tracking</li>
                        </ul>
                    </div>
                    <div class="ds-pill-group">
                        <span class="ds-pill">HubSpot CMS</span>
                        <span class="ds-pill">HubL</span>
                        <span class="ds-pill">JavaScript</span>
                        <span class="ds-pill">CSS</span>
                        <span class="ds-pill">Smart Content</span>
                    </div>
                    <div class="pricing-box">
                        <div class="pricing-item">
                            <span class="pricing-label">Timeline</span>
                            <span class="pricing-value">5–7 weeks</span>
                        </div>
                        <div class="pricing-item">
                            <span class="pricing-label">Investment</span>
                            <span class="pricing-value">$15,000 – $35,000</span>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Service 2: Landing Pages -->
        <section class="ds-section ds-section--subtle ds-section--border-b">
            <div class="ds-container service-block">
                <h3 class="ds-h3 service-title">High-Converting Landing Pages</h3>
                <div class="service-body">
                    <div class="service-subsection">
                        <p class="subsection-label">What it is</p>
                        <p class="ds-body">
                            Standalone landing pages built for paid ads, product
                            launches, or lead generation. We design for one
                            goal: conversion. A/B testing setup, performance
                            optimization (target &lt;1.5s load), and campaign
                            tracking.
                        </p>
                    </div>
                    <div class="service-subsection">
                        <p class="subsection-label">Ideal for</p>
                        <ul class="ds-check-list">
                            <li>Companies running paid ads (Google, Meta, LinkedIn)</li>
                            <li>Product launches needing dedicated campaign sites</li>
                            <li>Lead generation campaigns (ebooks, webinars, demos)</li>
                            <li>Teams wanting fast iteration (build, test, optimize)</li>
                        </ul>
                    </div>
                    <div class="pricing-box">
                        <div class="pricing-item">
                            <span class="pricing-label">Timeline</span>
                            <span class="pricing-value">2–3 weeks/page</span>
                        </div>
                        <div class="pricing-item">
                            <span class="pricing-label">Investment</span>
                            <span class="pricing-value">$3,000 – $8,000</span>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Service 3: Corporate Websites -->
        <section class="ds-section ds-section--border-b">
            <div class="ds-container service-block">
                <h3 class="ds-h3 service-title">Corporate Websites & Platforms</h3>
                <div class="service-body">
                    <div class="service-subsection">
                        <p class="subsection-label">What it is</p>
                        <p class="ds-body">
                            Full corporate websites built with modern frameworks
                            (Astro, Next.js, Sanity CMS). Multi-page sites with
                            blog, case studies, team pages, and resource
                            centers. SEO-optimized, performance-first.
                        </p>
                    </div>
                    <div class="service-subsection">
                        <p class="subsection-label">Ideal for</p>
                        <ul class="ds-check-list">
                            <li>Companies needing complete web presence (10+ pages)</li>
                            <li>Brands outgrowing WordPress or legacy CMS</li>
                            <li>Teams wanting modern stack (React, headless CMS, CI/CD)</li>
                            <li>International companies needing multi-language sites</li>
                        </ul>
                    </div>
                    <div class="ds-pill-group">
                        <span class="ds-pill">Astro</span>
                        <span class="ds-pill">Next.js</span>
                        <span class="ds-pill">React</span>
                        <span class="ds-pill">Sanity CMS</span>
                        <span class="ds-pill">Vercel</span>
                    </div>
                    <div class="pricing-box">
                        <div class="pricing-item">
                            <span class="pricing-label">Timeline</span>
                            <span class="pricing-value">10–14 weeks</span>
                        </div>
                        <div class="pricing-item">
                            <span class="pricing-label">Investment</span>
                            <span class="pricing-value">$25,000 – $60,000</span>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <CTABlock
            title="Let's Build Something Fast & Conversion-Focused"
            subtitle="Whether you need a landing page next week or a complete corporate site, we'll provide a detailed scope, timeline, and fixed-price proposal within 48 hours."
            primaryButtonText="Schedule Consultation"
            primaryButtonLink={`/${lang}/contact`}
            secondaryButtonText="View Case Studies"
            secondaryButtonLink={`/${lang}/projects`}
        />
    </main>
</Layout>

<style>
    .metrics-line {
        color: var(--fg-muted);
        margin-bottom: var(--space-8);
    }

    .section-title {
        margin-bottom: 0;
        font-weight: var(--font-normal);
        color: var(--fg-muted);
        font-size: var(--text-lg);
        font-family: var(--font-body);
        max-width: 700px;
    }

    .service-block {
        max-width: 900px;
    }

    .service-title {
        margin-bottom: var(--space-8);
        padding-bottom: var(--space-5);
        border-bottom: 1px solid var(--border);
    }

    .service-body {
        display: flex;
        flex-direction: column;
        gap: var(--space-6);
    }

    .service-subsection {
        display: flex;
        flex-direction: column;
        gap: var(--space-3);
    }

    .subsection-label {
        font-family: var(--font-display);
        font-size: var(--text-sm);
        font-weight: var(--font-semibold);
        color: var(--fg-muted);
        text-transform: uppercase;
        letter-spacing: 0.08em;
    }

    .pricing-box {
        display: flex;
        gap: var(--space-10);
        padding: var(--space-5) var(--space-6);
        border: 1px solid var(--border);
        border-left: 3px solid var(--accent);
        border-radius: var(--radius-sm);
        background-color: var(--surface);
        margin-top: var(--space-2);
    }

    .pricing-item {
        display: flex;
        flex-direction: column;
        gap: var(--space-1);
    }

    .pricing-label {
        font-size: var(--text-xs);
        color: var(--fg-muted);
        text-transform: uppercase;
        letter-spacing: 0.08em;
        font-family: var(--font-display);
    }

    .pricing-value {
        font-family: var(--font-display);
        font-size: var(--text-xl);
        font-weight: var(--font-bold);
        color: var(--fg);
    }

    @media (max-width: 768px) {
        .pricing-box {
            flex-direction: column;
            gap: var(--space-5);
        }
    }
</style>
