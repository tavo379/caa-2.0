---
import Layout from "../../../layouts/Layout.astro";
import CTABlock from "../../../components/CTABlock.astro";

const lang = "en";
const title =
    "HubSpot CRM & Automation | Implementation, Workflows & Integrations | Cacao & Avocado";
const description =
    "HubSpot CRM implementation, marketing automation, and system integrations. Shopify, Salesforce, Stripe, and custom API connections. 50+ deployments, 20 hrs/week saved.";
---

<Layout title={title} description={description} lang={lang}>
    <main>
        <!-- Hero -->
        <section class="ds-page-hero">
            <div class="ds-container">
                <h1 class="ds-h1">HubSpot CRM & Automation That Actually Drives Growth</h1>
                <p class="ds-body-lg">
                    We implement HubSpot CRM, build marketing automation
                    workflows, and integrate your entire growth stack. Our
                    automations save teams 20+ hours weekly and increase
                    marketing attribution accuracy by 60%.
                </p>
                <p class="ds-body metrics-line">
                    50+ implementations · 200+ automations deployed · 20 hrs/week saved
                </p>
                <div class="ds-btn-group">
                    <a href={`/${lang}/contact`} class="ds-btn ds-btn--primary">
                        Schedule HubSpot Consultation
                        <span class="ds-btn__dot" aria-hidden="true">●</span>
                    </a>
                    <a href={`/${lang}/projects`} class="ds-btn ds-btn--outline">
                        View Integration Work
                        <span class="ds-btn__dot" aria-hidden="true">→</span>
                    </a>
                </div>
            </div>
        </section>

        <!-- Overview -->
        <section class="ds-section ds-section--subtle ds-section--border-b">
            <div class="ds-container">
                <span class="ds-label">What We Build</span>
                <h2 class="ds-h2 section-title">
                    Three core HubSpot services: CRM implementation, marketing automation, and system integrations.
                </h2>
            </div>
        </section>

        <!-- Service 1: CRM -->
        <section class="ds-section ds-section--border-b">
            <div class="ds-container service-block">
                <h3 class="ds-h3 service-title">HubSpot CRM Implementation & Migration</h3>
                <div class="service-body">
                    <div class="service-subsection">
                        <p class="subsection-label">What it is</p>
                        <p class="ds-body">
                            Complete HubSpot CRM setup from scratch or migration
                            from Salesforce, Pipedrive, or custom systems. We
                            configure pipelines, custom properties, deal stages,
                            and reporting dashboards. You get a CRM tailored to
                            your sales process, not HubSpot's default.
                        </p>
                    </div>
                    <div class="service-subsection">
                        <p class="subsection-label">Ideal for</p>
                        <ul class="ds-check-list">
                            <li>Companies moving from spreadsheets to proper CRM</li>
                            <li>Teams migrating from Salesforce, Pipedrive, or legacy systems</li>
                            <li>Businesses needing custom deal pipelines (B2B, SaaS, agencies)</li>
                            <li>Sales teams wanting better reporting and forecasting</li>
                        </ul>
                    </div>
                    <div class="ds-pill-group">
                        <span class="ds-pill">HubSpot CRM</span>
                        <span class="ds-pill">HubSpot API</span>
                        <span class="ds-pill">Data Migration Tools</span>
                        <span class="ds-pill">Salesforce API</span>
                    </div>
                    <div class="pricing-box">
                        <div class="pricing-item">
                            <span class="pricing-label">Timeline</span>
                            <span class="pricing-value">4–6 weeks</span>
                        </div>
                        <div class="pricing-item">
                            <span class="pricing-label">Investment</span>
                            <span class="pricing-value">$8,000 – $20,000</span>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Service 2: Automation -->
        <section class="ds-section ds-section--subtle ds-section--border-b">
            <div class="ds-container service-block">
                <h3 class="ds-h3 service-title">Marketing Automation & Workflows</h3>
                <div class="service-body">
                    <div class="service-subsection">
                        <p class="subsection-label">What it is</p>
                        <p class="ds-body">
                            Automated lead nurture campaigns, lead scoring,
                            email sequences, and behavioral triggers. We build
                            workflows that qualify leads, route to sales, and
                            track attribution. Integrated with your CRM, website
                            forms, and ad platforms for complete funnel
                            visibility.
                        </p>
                    </div>
                    <div class="service-subsection">
                        <p class="subsection-label">Ideal for</p>
                        <ul class="ds-check-list">
                            <li>Marketing teams doing manual lead qualification</li>
                            <li>Companies with long sales cycles (B2B, SaaS, high-ticket)</li>
                            <li>Brands running multi-channel campaigns (email, ads, webinars)</li>
                            <li>Teams wanting better attribution (which campaigns drive revenue?)</li>
                        </ul>
                    </div>
                    <div class="pricing-box">
                        <div class="pricing-item">
                            <span class="pricing-label">Timeline</span>
                            <span class="pricing-value">5–8 weeks</span>
                        </div>
                        <div class="pricing-item">
                            <span class="pricing-label">Investment</span>
                            <span class="pricing-value">$10,000 – $25,000</span>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Service 3: Integrations -->
        <section class="ds-section ds-section--border-b">
            <div class="ds-container service-block">
                <h3 class="ds-h3 service-title">HubSpot System Integrations</h3>
                <div class="service-body">
                    <div class="service-subsection">
                        <p class="subsection-label">What it is</p>
                        <p class="ds-body">
                            Connect HubSpot to your entire tech stack: Shopify,
                            Salesforce, payment processors (Stripe), customer
                            support (Zendesk), and custom APIs. Two-way sync for
                            contacts, orders, and activities. We build custom
                            integrations when native apps don't exist or don't
                            meet your needs.
                        </p>
                    </div>
                    <div class="service-subsection">
                        <p class="subsection-label">Ideal for</p>
                        <ul class="ds-check-list">
                            <li>E-commerce brands syncing Shopify orders to HubSpot</li>
                            <li>Companies using HubSpot + Salesforce (need bi-directional sync)</li>
                            <li>SaaS products tracking product usage in HubSpot</li>
                            <li>Teams with custom systems needing HubSpot integration</li>
                        </ul>
                    </div>
                    <div class="ds-pill-group">
                        <span class="ds-pill">HubSpot API</span>
                        <span class="ds-pill">Shopify API</span>
                        <span class="ds-pill">Salesforce API</span>
                        <span class="ds-pill">Stripe API</span>
                        <span class="ds-pill">Node.js</span>
                    </div>
                    <div class="pricing-box">
                        <div class="pricing-item">
                            <span class="pricing-label">Timeline</span>
                            <span class="pricing-value">3–6 weeks</span>
                        </div>
                        <div class="pricing-item">
                            <span class="pricing-label">Investment</span>
                            <span class="pricing-value">$5,000 – $18,000</span>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <CTABlock
            title="Let's Audit Your HubSpot Setup"
            subtitle="Already using HubSpot? We'll audit your current setup and identify quick wins. Considering HubSpot? We'll assess if it's the right fit and provide an implementation roadmap."
            primaryButtonText="Schedule Free Audit"
            primaryButtonLink={`/${lang}/contact`}
            secondaryButtonText="Tell Us About Your Stack"
            secondaryButtonLink={`/${lang}/contact`}
        />
    </main>
</Layout>

<style>
    .metrics-line {
        color: var(--fg-muted);
        margin-bottom: var(--space-8);
    }

    .section-title {
        margin-bottom: 0;
        font-weight: var(--font-normal);
        color: var(--fg-muted);
        font-size: var(--text-lg);
        font-family: var(--font-body);
        max-width: 700px;
    }

    .service-block {
        max-width: 900px;
    }

    .service-title {
        margin-bottom: var(--space-8);
        padding-bottom: var(--space-5);
        border-bottom: 1px solid var(--border);
    }

    .service-body {
        display: flex;
        flex-direction: column;
        gap: var(--space-6);
    }

    .service-subsection {
        display: flex;
        flex-direction: column;
        gap: var(--space-3);
    }

    .subsection-label {
        font-family: var(--font-display);
        font-size: var(--text-sm);
        font-weight: var(--font-semibold);
        color: var(--fg-muted);
        text-transform: uppercase;
        letter-spacing: 0.08em;
    }

    .pricing-box {
        display: flex;
        gap: var(--space-10);
        padding: var(--space-5) var(--space-6);
        border: 1px solid var(--border);
        border-left: 3px solid var(--accent);
        border-radius: var(--radius-sm);
        background-color: var(--surface);
        margin-top: var(--space-2);
    }

    .pricing-item {
        display: flex;
        flex-direction: column;
        gap: var(--space-1);
    }

    .pricing-label {
        font-size: var(--text-xs);
        color: var(--fg-muted);
        text-transform: uppercase;
        letter-spacing: 0.08em;
        font-family: var(--font-display);
    }

    .pricing-value {
        font-family: var(--font-display);
        font-size: var(--text-xl);
        font-weight: var(--font-bold);
        color: var(--fg);
    }

    @media (max-width: 768px) {
        .pricing-box {
            flex-direction: column;
            gap: var(--space-5);
        }
    }
</style>
