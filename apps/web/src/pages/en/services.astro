---
import Layout from "../../layouts/Layout.astro";
import CTABlock from "../../components/CTABlock.astro";

const lang = "en";
const title = "E-commerce & Web Development Services | Cacao & Avocado";
const description =
    "Shopify development, WooCommerce builds, corporate websites, landing pages, and HubSpot integrations. Senior-level engineering for brands in Colombia and the US.";
---

<Layout title={title} description={description} lang={lang}>
    <main>
        <!-- Hero -->
        <section class="ds-page-hero">
            <div class="ds-container">
                <h1 class="ds-h1">E-commerce &amp; Web Development Services</h1>
                <p class="ds-body-lg">
                    From Shopify stores and WooCommerce builds to corporate
                    websites and HubSpot integrations — we deliver senior-level
                    engineering for brands in Colombia and the United States.
                </p>
                <div class="ds-btn-group">
                    <a href={`/${lang}/contact`} class="ds-btn ds-btn--primary">
                        Get a Free Estimate
                        <span class="ds-btn__dot" aria-hidden="true">●</span>
                    </a>
                </div>
            </div>
        </section>

        <!-- Service Cards -->
        <section class="ds-section ds-section--subtle ds-section--border-b">
            <div class="ds-container">
                <span class="ds-label">Our Services</span>
                <h2 class="ds-h2 section-title">Three core specialties. One integrated team.</h2>

                <div class="ds-grid-3">
                    <div class="ds-service-card">
                        <p class="ds-service-card__title">Shopify Development</p>
                        <p class="ds-service-card__body">
                            We build custom Shopify stores from the ground up —
                            theme development, app integrations, checkout
                            customization, and headless architecture with
                            Hydrogen and Remix. Whether you're launching your
                            first store or migrating from another platform, we
                            handle the full build.
                        </p>
                        <ul class="ds-check-list">
                            <li>Custom theme development or theme customization</li>
                            <li>Product catalog setup and collections architecture</li>
                            <li>Payment gateway and shipping integration</li>
                            <li>Checkout optimization and conversion improvements</li>
                            <li>App integrations (reviews, subscriptions, loyalty, etc.)</li>
                            <li>Headless Shopify with Hydrogen/Remix for brands needing maximum performance</li>
                        </ul>
                        <div class="ds-pill-group">
                            <span class="ds-pill">Shopify</span>
                            <span class="ds-pill">Hydrogen</span>
                            <span class="ds-pill">Remix</span>
                            <span class="ds-pill">Liquid</span>
                            <span class="ds-pill">React</span>
                            <span class="ds-pill">GraphQL</span>
                        </div>
                        <a href={`/${lang}/services/ecommerce-engineering`} class="ds-btn ds-btn--outline card-cta">
                            Explore Shopify Services
                            <span class="ds-btn__dot" aria-hidden="true">→</span>
                        </a>
                    </div>

                    <div class="ds-service-card">
                        <p class="ds-service-card__title">Corporate Websites &amp; Portfolios</p>
                        <p class="ds-service-card__body">
                            High-performance corporate sites, creative
                            portfolios, and presentation websites built with
                            modern frameworks. Fast load times, clean code, and
                            CMS systems your team can manage independently.
                        </p>
                        <ul class="ds-check-list">
                            <li>Architecture firms, creative studios, B2B companies</li>
                            <li>Fast, clean, and easy for your team to manage</li>
                            <li>85+ Lighthouse scores on every delivery</li>
                        </ul>
                        <div class="ds-pill-group">
                            <span class="ds-pill">Astro</span>
                            <span class="ds-pill">Next.js</span>
                            <span class="ds-pill">WordPress</span>
                            <span class="ds-pill">Sanity CMS</span>
                            <span class="ds-pill">React</span>
                        </div>
                        <a href={`/${lang}/services/web-development`} class="ds-btn ds-btn--outline card-cta">
                            Explore Web Development
                            <span class="ds-btn__dot" aria-hidden="true">→</span>
                        </a>
                    </div>

                    <div class="ds-service-card">
                        <p class="ds-service-card__title">HubSpot Development &amp; Automation</p>
                        <p class="ds-service-card__body">
                            HubSpot CMS websites, CRM implementations, and
                            marketing automation workflows. We connect your
                            website to your sales pipeline and build automation
                            that saves your team hours every week.
                        </p>
                        <ul class="ds-check-list">
                            <li>B2B companies, SaaS brands, and any business using HubSpot</li>
                            <li>CRM setup, lead scoring, and nurture campaigns</li>
                            <li>System integrations (Shopify, payment processors, APIs)</li>
                        </ul>
                        <div class="ds-pill-group">
                            <span class="ds-pill">HubSpot CMS</span>
                            <span class="ds-pill">HubL</span>
                            <span class="ds-pill">HubSpot API</span>
                            <span class="ds-pill">Shopify API</span>
                            <span class="ds-pill">Node.js</span>
                        </div>
                        <a href={`/${lang}/services/hubspot-automation`} class="ds-btn ds-btn--outline card-cta">
                            Explore HubSpot Services
                            <span class="ds-btn__dot" aria-hidden="true">→</span>
                        </a>
                    </div>
                </div>
            </div>
        </section>

        <!-- Why Work With Us -->
        <section class="ds-section ds-section--border-b">
            <div class="ds-container">
                <span class="ds-label">Why Us</span>
                <h2 class="ds-h2 section-title">Why Work With Us</h2>
                <p class="ds-body-lg why-intro">
                    Most agencies are specialized in one area. We're
                    multi-disciplinary by design — which means we can architect
                    your entire growth stack, not just pieces of it.
                </p>
                <div class="ds-grid-3">
                    <div class="ds-principle">
                        <p class="ds-principle__title">Senior-Level Engineering Only</p>
                        <p class="ds-principle__body">
                            No junior devs learning on your dime. Our team has
                            11+ years each, with experience at BairesDev,
                            Globant, and Zemoga. We've shipped for Disney,
                            Walmart, and multinational finance platforms
                            processing millions in transactions daily.
                        </p>
                    </div>
                    <div class="ds-principle">
                        <p class="ds-principle__title">Full-Stack Commerce Expertise</p>
                        <p class="ds-principle__body">
                            We don't just do front-end, or just Shopify, or just
                            marketing automation. We architect complete
                            solutions: headless storefronts connected to HubSpot
                            CRMs, with automated workflows and performance
                            monitoring. One team, zero handoffs.
                        </p>
                    </div>
                    <div class="ds-principle">
                        <p class="ds-principle__title">Your Timezone, Your Language</p>
                        <p class="ds-principle__body">
                            Based in Medellín, Colombia with full EST/CST
                            overlap. Fluent English and Spanish. Daily standups,
                            Slack/email responsiveness within 2 hours, and clear
                            technical documentation. We work like an in-house
                            team, not an offshore vendor.
                        </p>
                    </div>
                </div>
            </div>
        </section>

        <!-- Process -->
        <section class="ds-section ds-section--subtle ds-section--border-b">
            <div class="ds-container">
                <span class="ds-label">Our Process</span>
                <h2 class="ds-h2 section-title">How a Project Works</h2>
                <p class="ds-body-lg process-intro">
                    Every project is different, but our approach is consistent:
                    understand the business goal first, then architect the
                    technical solution.
                </p>

                <div class="process-steps">
                    <div class="ds-step">
                        <p class="ds-step__number">01</p>
                        <p class="ds-step__title">Discovery Call (Free)</p>
                        <p class="ds-step__body">
                            30-minute call to understand your project, goals,
                            and timeline. We'll tell you honestly if we're the
                            right fit.
                        </p>
                        <span class="ds-step__badge">Free</span>
                    </div>

                    <div class="ds-step">
                        <p class="ds-step__number">02</p>
                        <p class="ds-step__title">Proposal &amp; Scope</p>
                        <p class="ds-step__body">
                            Detailed proposal with scope, timeline, and fixed
                            price. No vague estimates — you know exactly what
                            you're getting before you commit.
                        </p>
                        <span class="ds-step__badge">3–5 days</span>
                    </div>

                    <div class="ds-step">
                        <p class="ds-step__number">03</p>
                        <p class="ds-step__title">Build</p>
                        <p class="ds-step__body">
                            Agile development with weekly updates, demos, and a
                            shared project board. You see progress in real time.
                        </p>
                        <span class="ds-step__badge">4–12 weeks</span>
                    </div>

                    <div class="ds-step">
                        <p class="ds-step__number">04</p>
                        <p class="ds-step__title">Launch &amp; Support</p>
                        <p class="ds-step__body">
                            Coordinated launch with 30 days of included support.
                            We don't disappear after delivery.
                        </p>
                        <span class="ds-step__badge">Ongoing</span>
                    </div>
                </div>
            </div>
        </section>

        <CTABlock
            title="Ready to Start?"
            subtitle="Tell us about your project and we'll respond within 24 hours with a technical approach and a clear estimate."
            primaryButtonText="Start a Project"
            primaryButtonLink={`/${lang}/contact`}
            secondaryButtonText="Schedule a Call"
            secondaryButtonLink={`/${lang}/contact`}
        />
    </main>
</Layout>

<style>
    .section-title {
        margin-bottom: var(--space-10);
    }

    .why-intro,
    .process-intro {
        max-width: 700px;
        margin-bottom: var(--space-12);
    }

    .card-cta {
        margin-top: auto;
        align-self: flex-start;
    }

    .process-steps {
        display: grid;
        gap: var(--space-4);
        max-width: 800px;
    }
</style>
