---
import Layout from "../../layouts/Layout.astro";
import Hero from "../../components/Hero.astro";
import Services from "../../components/Services.astro";
import AboutHome from "../../components/AboutHome.astro";
import ProjectsHome from "../../components/ProjectsHome.astro";
import MetricsSection from "../../components/MetricsSection.astro";
import TechStack from "../../components/TechStack.astro";
import CTABlock from "../../components/CTABlock.astro";
import { ui } from "../../i18n/ui";

const lang = "en";
const t = ui[lang];

const title =
    "Cacao & Avocado | Shopify & Web Development Agency | Colombia & US";
const description =
    "Premium e-commerce and web development agency based in Medellín. We build Shopify stores, corporate websites, and HubSpot integrations for brands in Colombia and the United States.";
---

<Layout title={title} description={description} lang={lang}>
    <main>
        <Hero
            title={`Welcome to the Authenticity of the <span class="accent">Tropics</span>`}
            subtitle="We build Shopify stores, high-performance websites, and HubSpot integrations for ambitious brands in Colombia and the US. Senior-level engineering, no shortcuts, no fluff."
            ctaPrimary="Get a Quote"
            ctaPrimaryHref={`/${lang}/contact`}
            ctaSecondary="Our Services"
            ctaSecondaryHref="#servicios"
            lang={lang}
        />
        <Services
            title={t["services.title"]}
            shopifyTitle="E-commerce Development"
            shopifyDesc="Shopify and WooCommerce stores built to convert. From custom theme development and checkout optimization to headless architecture — we build e-commerce experiences that drive revenue, not just traffic."
            hubspotTitle="HubSpot & Automation"
            hubspotDesc="HubSpot CMS development, CRM setup, and marketing automation that connects your website to your sales pipeline. We build the technical side so your team can focus on closing deals."
            webTitle="Web Development & CMS"
            webDesc="Corporate websites, creative portfolios, and landing pages built for performance. Fast, clean, and easy for your team to manage — whether you're an architecture firm in Medellín or a startup in Miami."
            lang={lang}
        />
        <ProjectsHome
            title={t["projects.title"]}
            intro="Some of our recent work in Shopify, web development, and HubSpot."
            viewAll={t["projects.viewAll"]}
            viewProject={t["projects.viewProject"]}
            empty={t["projects.empty"]}
            lang={lang}
        />
        <MetricsSection
            title="By the Numbers"
            metric1Number="11+"
            metric1Label="Years of Engineering Experience"
            metric2Number="20+"
            metric2Label="Projects Delivered Across Colombia & the US"
            metric3Number="85+"
            metric3Label="Average Lighthouse Score"
            metric4Number="2"
            metric4Label="Markets. One Standard of Quality."
        />
        <TechStack
            title="Technologies We Work With"
            subtitle="Our multi-specialty approach means we can architect complete solutions, not just pieces. These are the platforms and frameworks we deploy daily."
        />
        <CTABlock
            title="Ready to Build Something That Actually Performs?"
            subtitle="Tell us about your project. We'll come back within 24 hours with a technical approach and a clear estimate. No vague proposals, no surprise invoices."
            primaryButtonText="Start a Project"
            primaryButtonLink={`/${lang}/contact`}
        />
    </main>
</Layout>
