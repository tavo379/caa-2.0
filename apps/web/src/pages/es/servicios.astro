---
import Layout from "../../layouts/Layout.astro";
import { ArrowRight } from "lucide-astro";
import CTABlock from "../../components/CTABlock.astro";

const lang = "es";
const title = "Servicios de Desarrollo E-commerce y Web | Cacao & Avocado";
const description =
    "Desarrollo Shopify, builds WooCommerce, sitios corporativos, landing pages e integraciones HubSpot. Ingeniería de nivel senior para marcas en Colombia y EE.UU.";
---

<Layout title={title} description={description} lang={lang}>
    <main>
        <!-- Hero -->
        <section class="ds-page-hero">
            <div class="ds-container">
                <h1 class="ds-h1">
                    Servicios de Desarrollo E-commerce y Web
                </h1>
                <p class="ds-body-lg">
                    Desde tiendas Shopify y builds WooCommerce hasta sitios
                    corporativos e integraciones HubSpot — entregamos ingeniería
                    de nivel senior para marcas en Colombia y Estados Unidos.
                </p>
                <div class="ds-btn-group">
                    <a href={`/${lang}/contacto`} class="ds-btn ds-btn--primary">
                        Solicitar Cotización Gratis
                        <span class="ds-btn__dot"><ArrowRight size={12} strokeWidth={2} /></span>
                    </a>
                </div>
            </div>
        </section>

        <!-- Service Cards -->
        <section class="ds-section ds-section--subtle ds-section--border-b">
            <div class="ds-container">
                <span class="ds-label">Nuestros Servicios</span>
                <h2 class="ds-h2 section-title">Tres especialidades principales. Un equipo integrado.</h2>

                <div class="ds-grid-3">
                    <div class="ds-service-card">
                        <p class="ds-service-card__title">Desarrollo Shopify</p>
                        <p class="ds-service-card__body">
                            Construimos tiendas Shopify custom desde cero —
                            desarrollo de temas, integraciones de apps,
                            personalización de checkout y arquitectura headless
                            con Hydrogen y Remix. Ya sea que estés lanzando tu
                            primera tienda o migrando desde otra plataforma,
                            manejamos el build completo.
                        </p>
                        <ul class="ds-check-list">
                            <li>Desarrollo de tema custom o personalización de tema</li>
                            <li>Configuración de catálogo y arquitectura de colecciones</li>
                            <li>Integración de pasarelas de pago y envío</li>
                            <li>Optimización de checkout y mejoras de conversión</li>
                            <li>Integraciones de apps (reseñas, suscripciones, fidelidad, etc.)</li>
                        </ul>
                        <div class="ds-pill-group">
                            <span class="ds-pill">Shopify</span>
                            <span class="ds-pill">Hydrogen</span>
                            <span class="ds-pill">Remix</span>
                            <span class="ds-pill">Liquid</span>
                            <span class="ds-pill">React</span>
                        </div>
                        <a href="/es/servicios/ecommerce-engineering" class="ds-btn ds-btn--outline card-cta">
                            Ver Servicio
                            <span class="ds-btn__dot"><ArrowRight size={12} strokeWidth={2} /></span>
                        </a>
                    </div>

                    <div class="ds-service-card">
                        <p class="ds-service-card__title">Sitios Corporativos y Portafolios</p>
                        <p class="ds-service-card__body">
                            Sitios corporativos de alto rendimiento, portafolios
                            creativos y sitios de presentación construidos con
                            frameworks modernos. Rápidos, limpios y con CMS que
                            tu equipo puede manejar independientemente.
                        </p>
                        <ul class="ds-check-list">
                            <li>Firmas de arquitectura, estudios creativos, empresas B2B</li>
                            <li>Rápido, limpio y fácil de gestionar para tu equipo</li>
                            <li>Puntuaciones Lighthouse 85+ en cada entrega</li>
                        </ul>
                        <div class="ds-pill-group">
                            <span class="ds-pill">Astro</span>
                            <span class="ds-pill">Next.js</span>
                            <span class="ds-pill">WordPress</span>
                            <span class="ds-pill">Sanity CMS</span>
                            <span class="ds-pill">React</span>
                        </div>
                        <a href="/es/servicios/web-development" class="ds-btn ds-btn--outline card-cta">
                            Ver Servicio
                            <span class="ds-btn__dot"><ArrowRight size={12} strokeWidth={2} /></span>
                        </a>
                    </div>

                    <div class="ds-service-card">
                        <p class="ds-service-card__title">Desarrollo HubSpot y Automatización</p>
                        <p class="ds-service-card__body">
                            Sitios HubSpot CMS, implementaciones CRM y workflows
                            de automatización de marketing. Conectamos tu sitio
                            web con tu pipeline de ventas y construimos
                            automatización que le ahorra horas semanales a tu
                            equipo.
                        </p>
                        <ul class="ds-check-list">
                            <li>Empresas B2B, marcas SaaS y cualquier negocio que use HubSpot</li>
                            <li>Setup de CRM, lead scoring y campañas de nurture</li>
                            <li>Integraciones de sistemas (Shopify, procesadores de pago, APIs)</li>
                        </ul>
                        <div class="ds-pill-group">
                            <span class="ds-pill">HubSpot CMS</span>
                            <span class="ds-pill">HubL</span>
                            <span class="ds-pill">HubSpot API</span>
                            <span class="ds-pill">Node.js</span>
                        </div>
                        <a href="/es/servicios/hubspot-automation" class="ds-btn ds-btn--outline card-cta">
                            Ver Servicio
                            <span class="ds-btn__dot"><ArrowRight size={12} strokeWidth={2} /></span>
                        </a>
                    </div>
                </div>
            </div>
        </section>

        <!-- Process -->
        <section class="ds-section ds-section--border-b">
            <div class="ds-container">
                <span class="ds-label">Nuestro Proceso</span>
                <h2 class="ds-h2 section-title">Cómo Funciona un Proyecto</h2>
                <p class="ds-body-lg process-intro">
                    Cada proyecto es diferente, pero nuestro enfoque es
                    consistente: entender el objetivo de negocio primero,
                    luego diseñar la solución técnica.
                </p>

                <div class="process-steps">
                    <div class="ds-step">
                        <p class="ds-step__number">01</p>
                        <p class="ds-step__title">Llamada de Discovery (Gratis)</p>
                        <p class="ds-step__body">
                            30 minutos para entender tu proyecto, objetivos y
                            timeline. Te diremos honestamente si somos el
                            equipo adecuado.
                        </p>
                        <span class="ds-step__badge">Gratis</span>
                    </div>

                    <div class="ds-step">
                        <p class="ds-step__number">02</p>
                        <p class="ds-step__title">Propuesta y Alcance</p>
                        <p class="ds-step__body">
                            Propuesta detallada con alcance, timeline y precio
                            fijo. Sin estimados vagos — sabes exactamente qué
                            estás obteniendo antes de comprometerte.
                        </p>
                        <span class="ds-step__badge">3–5 días</span>
                    </div>

                    <div class="ds-step">
                        <p class="ds-step__number">03</p>
                        <p class="ds-step__title">Construcción</p>
                        <p class="ds-step__body">
                            Desarrollo ágil con actualizaciones semanales,
                            demos y un tablero de proyecto compartido. Ves el
                            progreso en tiempo real.
                        </p>
                        <span class="ds-step__badge">4–12 semanas</span>
                    </div>

                    <div class="ds-step">
                        <p class="ds-step__number">04</p>
                        <p class="ds-step__title">Lanzamiento y Soporte</p>
                        <p class="ds-step__body">
                            Lanzamiento coordinado con 30 días de soporte
                            incluido. No desaparecemos después de la entrega.
                        </p>
                        <span class="ds-step__badge">Continuo</span>
                    </div>
                </div>
            </div>
        </section>

        <CTABlock
            title="¿Listo Para Iniciar?"
            subtitle="Cuéntanos sobre tu proyecto y respondemos en 24 horas con un enfoque técnico y un presupuesto claro."
            primaryButtonText="Iniciar un Proyecto"
            primaryButtonLink={`/${lang}/contacto`}
            secondaryButtonText="Agendar una Llamada"
            secondaryButtonLink={`/${lang}/contacto`}
        />
    </main>
</Layout>

<style>
    .section-title {
        margin-bottom: var(--space-10);
    }

    .process-intro {
        max-width: 700px;
        margin-bottom: var(--space-12);
    }

    .card-cta {
        margin-top: auto;
        align-self: flex-start;
    }

    .process-steps {
        display: grid;
        gap: var(--space-4);
        max-width: 800px;
    }
</style>
