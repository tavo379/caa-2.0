---
import Layout from "../../../layouts/Layout.astro";
import { ArrowRight } from "lucide-astro";
import { sanityClient } from "sanity:client";
import groq from "groq";
import { PortableText } from "astro-portabletext";

export async function getStaticPaths() {
    const rows = await sanityClient.fetch(groq`
    *[_type=="project" && language=="es"]{ "slug": slug.current }
  `);
    return rows.map((x: any) => ({ params: { slug: x.slug } }));
}

const { slug } = Astro.params;
const lang = "es";

const project = await sanityClient.fetch(
    groq`
*[_type=="project" && language=="es" && slug.current==$slug][0]{
  title,
  excerpt,
  body,
  cover{asset->{url}, alt},
  tech,
  links,
  publishedAt
}
`,
    { slug },
);

if (!project) {
    return Astro.redirect("/404");
}

const title = `${project.title} — Cacao & Avocado`;
const description = project.excerpt || `Proyecto: ${project.title}`;
---

<Layout title={title} description={description} lang={lang}>
    <article>
        <section class="ds-page-hero">
            <div class="ds-container project-header">
                <h1 class="ds-h1">{project.title}</h1>
                {project.excerpt && <p class="ds-body-lg">{project.excerpt}</p>}
                {
                    project.tech && project.tech.length > 0 && (
                        <div class="ds-pill-group">
                            {project.tech.map((tech: string) => (
                                <span class="ds-pill">{tech}</span>
                            ))}
                        </div>
                    )
                }
            </div>
        </section>

        <section class="ds-section">
            <div class="ds-container content-wrap">
                {
                    project.cover?.asset?.url && (
                        <div class="cover-image">
                            <img
                                src={project.cover.asset.url}
                                alt={project.cover.alt ?? project.title}
                                loading="lazy"
                                decoding="async"
                            />
                        </div>
                    )
                }

                <div class="ds-prose project-content">
                    {project.body && <PortableText value={project.body} />}
                </div>

                {
                    project.links &&
                        (project.links.siteUrl || project.links.repoUrl) && (
                            <div class="ds-btn-group project-links">
                                {project.links.siteUrl && (
                                    <a
                                        href={project.links.siteUrl}
                                        target="_blank"
                                        rel="noopener noreferrer"
                                        class="ds-btn ds-btn--primary"
                                    >
                                        Ver Sitio Web
                                        <span class="ds-btn__dot"><ArrowRight size={12} strokeWidth={2} /></span>
                                    </a>
                                )}
                                {project.links.repoUrl && (
                                    <a
                                        href={project.links.repoUrl}
                                        target="_blank"
                                        rel="noopener noreferrer"
                                        class="ds-btn ds-btn--outline"
                                    >
                                        Ver Repositorio
                                        <span class="ds-btn__dot"><ArrowRight size={12} strokeWidth={2} /></span>
                                    </a>
                                )}
                            </div>
                        )
                }

                <div class="back-link">
                    <a href={`/${lang}/proyectos`} class="ds-btn ds-btn--outline">
                        ← Volver a Proyectos
                    </a>
                </div>
            </div>
        </section>
    </article>
</Layout>

<style>
    .project-header {
        display: flex;
        flex-direction: column;
        gap: var(--space-5);
    }

    .content-wrap {
        max-width: 800px;
    }

    .cover-image {
        margin-bottom: var(--space-10);
        border-radius: var(--radius-md);
        overflow: hidden;
        border: 1px solid var(--border);
    }

    .cover-image img {
        width: 100%;
        height: auto;
        display: block;
        filter: grayscale(20%);
    }

    .project-content {
        margin-bottom: var(--space-10);
    }

    .project-content :global(a) {
        color: var(--accent);
        text-decoration: underline;
    }

    .project-links {
        margin-bottom: var(--space-8);
    }

    .back-link {
        margin-top: var(--space-4);
    }
</style>
