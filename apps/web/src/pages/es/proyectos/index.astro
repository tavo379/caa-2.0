---
import Layout from "../../../layouts/Layout.astro";
import { ArrowRight } from "lucide-astro";
import { sanityClient } from "sanity:client";
import groq from "groq";

const lang = "es";

const projects = await sanityClient.fetch(
    groq`
  *[_type == "project" && language == $lang] | order(system.publishedAt desc) {
    _id,
    title,
    "slug": slug.current,
    "imageUrl": cover.asset->url,
    "tech": tech[]
  }
`,
    { lang },
);

const title = "Proyectos — Cacao & Avocado";
const description = "Nuestro trabajo reciente en Shopify, HubSpot y Desarrollo Web.";
---

<Layout title={title} description={description} lang={lang}>
    <main>
        <section class="ds-page-hero">
            <div class="ds-container">
                <h1 class="ds-h1">Nuestros Proyectos</h1>
                <p class="ds-body-lg">Explora nuestros casos de éxito más recientes.</p>
            </div>
        </section>

        <section class="ds-section">
            <div class="ds-container">
                <div class="projects-grid">
                    {
                        projects.length > 0 ? (
                            projects.map((project: any) => (
                                <div class="ds-project-card">
                                    <div class="ds-project-card__image">
                                        {project.imageUrl ? (
                                            <img
                                                src={project.imageUrl}
                                                alt={project.title}
                                            />
                                        ) : (
                                            <div class="ds-project-card__placeholder">
                                                {project.title}
                                            </div>
                                        )}
                                    </div>
                                    <div class="ds-project-card__body">
                                        <p class="ds-project-card__title">
                                            {project.title}
                                        </p>
                                        <p class="ds-project-card__tech">
                                            {project.tech
                                                ? project.tech.join(", ")
                                                : "Desarrollo Web"}
                                        </p>
                                        <div class="ds-project-card__cta">
                                            <a
                                                href={`/${lang}/proyectos/${project.slug}`}
                                                class="ds-btn ds-btn--outline"
                                            >
                                                Ver Proyecto
                                                <span class="ds-btn__dot"><ArrowRight size={12} strokeWidth={2} /></span>
                                            </a>
                                        </div>
                                    </div>
                                </div>
                            ))
                        ) : (
                            <p class="empty-state ds-body">Pronto publicaremos nuestros proyectos.</p>
                        )
                    }
                </div>
            </div>
        </section>
    </main>
</Layout>

<style>
    .projects-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: var(--space-6);
    }

    .empty-state {
        grid-column: 1 / -1;
        text-align: center;
        padding: var(--space-16) 0;
        color: var(--fg-muted);
    }
</style>
