---
import Layout from "../../layouts/Layout.astro";

const lang = "es";
const title =
    "Contacto | Agenda una Llamada o Envía Detalles del Proyecto | Cacao & Avocado";
const description =
    "Ponte en contacto para ingeniería de e-commerce, desarrollo web o automatización HubSpot. Tiempo de respuesta de 24 horas. Basados en Medellín, compatibles EST/CST. Inglés y español.";
---

<Layout title={title} description={description} lang={lang}>
    <main>
        <!-- Hero -->
        <section class="ds-page-hero">
            <div class="ds-container">
                <h1 class="ds-h1">Hablemos de Tu Proyecto</h1>
                <p class="ds-body-lg">
                    Agenda una llamada rápida o envíanos los detalles de tu
                    proyecto. Normalmente respondemos en 24 horas con un enfoque
                    técnico y estimado de costo — sin discurso de ventas, solo
                    perspectiva ingenieril.
                </p>
            </div>
        </section>

        <!-- Contact Options -->
        <section class="ds-section ds-section--subtle ds-section--border-b">
            <div class="ds-container">
                <p class="ds-body options-lead">Elige cómo te gustaría conectar:</p>

                <div class="contact-grid">
                    <div class="contact-option">
                        <p class="ds-h3">Agenda una Llamada de Discovery</p>
                        <p class="ds-body">
                            Llamada de video de 30 minutos para discutir tu
                            proyecto, responder preguntas técnicas y explorar si
                            somos un buen fit. Sin compromiso requerido.
                        </p>
                        <ul class="ds-check-list">
                            <li>Discusión técnica (no un discurso de ventas)</li>
                            <li>Estimado de cronograma y costo aproximado</li>
                            <li>Próximos pasos si seguimos adelante</li>
                        </ul>
                        <a
                            href="https://calendly.com/cacaoandavocado"
                            class="ds-btn ds-btn--primary"
                            target="_blank"
                            rel="noopener noreferrer"
                        >
                            Agendar en Calendly
                            <span class="ds-btn__dot" aria-hidden="true">●</span>
                        </a>
                    </div>

                    <div class="contact-option">
                        <p class="ds-h3">Enviar Detalles del Proyecto</p>
                        <p class="ds-body">
                            ¿Prefieres escribirlo? Cuéntanos sobre tu proyecto y
                            responderemos en 24 horas.
                        </p>
                        <form class="contact-form" name="contact-es" netlify>
                            <input
                                type="text"
                                name="nombre"
                                placeholder="Tu nombre*"
                                required
                            />
                            <input
                                type="email"
                                name="email"
                                placeholder="tu@empresa.com*"
                                required
                            />
                            <input
                                type="text"
                                name="empresa"
                                placeholder="Nombre de la empresa (opcional)"
                            />
                            <select name="servicio" required>
                                <option value="">Servicio necesitado*</option>
                                <option>Ingeniería E-commerce</option>
                                <option>Desarrollo Web y CMS</option>
                                <option>CRM y Automatización HubSpot</option>
                                <option>Múltiples Servicios</option>
                                <option>No estoy seguro todavía</option>
                            </select>
                            <select name="presupuesto" required>
                                <option value="">Rango de presupuesto*</option>
                                <option>Menos de $10k</option>
                                <option>$10k - $25k</option>
                                <option>$25k - $50k</option>
                                <option>$50k - $100k</option>
                                <option>$100k+</option>
                                <option>Necesito ayuda estimando</option>
                            </select>
                            <textarea
                                name="descripcion"
                                rows="6"
                                placeholder="Cuéntanos sobre tu proyecto: objetivos, desafíos, cronograma...*"
                                required></textarea>
                            <select name="cronograma">
                                <option value="">Cronograma (opcional)</option>
                                <option>ASAP (1-2 semanas)</option>
                                <option>1-2 meses</option>
                                <option>2-3 meses</option>
                                <option>Flexible / Solo explorando</option>
                            </select>
                            <button type="submit" class="ds-btn ds-btn--primary">
                                Enviar Brief del Proyecto
                                <span class="ds-btn__dot" aria-hidden="true">●</span>
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </section>

        <!-- Direct Contact -->
        <section class="ds-section">
            <div class="ds-container">
                <span class="ds-label">Contacto Directo</span>
                <h2 class="ds-h2 info-title">O Contáctanos Directamente</h2>
                <div class="info-grid">
                    <div class="info-item">
                        <p class="info-key">Email</p>
                        <p class="ds-body">hello@cacaoandavocado.co</p>
                    </div>
                    <div class="info-item">
                        <p class="info-key">Ubicados en</p>
                        <p class="ds-body">Medellín, Colombia</p>
                    </div>
                    <div class="info-item">
                        <p class="info-key">Zona Horaria</p>
                        <p class="ds-body">GMT-5 (compatible EST/CST)</p>
                    </div>
                    <div class="info-item">
                        <p class="info-key">Idiomas</p>
                        <p class="ds-body">Inglés y Español</p>
                    </div>
                </div>
            </div>
        </section>
    </main>
</Layout>

<style>
    .options-lead {
        margin-bottom: var(--space-10);
    }

    .contact-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(380px, 1fr));
        gap: var(--space-8);
    }

    .contact-option {
        display: flex;
        flex-direction: column;
        gap: var(--space-5);
    }

    .contact-form {
        display: flex;
        flex-direction: column;
        gap: var(--space-3);
    }

    .contact-form input,
    .contact-form select,
    .contact-form textarea {
        padding: var(--space-3) var(--space-4);
        background-color: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius-sm);
        font-size: var(--text-base);
        font-family: var(--font-body);
        color: var(--fg);
        transition: border-color var(--ease);
        width: 100%;
    }

    .contact-form input::placeholder,
    .contact-form textarea::placeholder {
        color: var(--fg-muted);
    }

    .contact-form input:focus,
    .contact-form select:focus,
    .contact-form textarea:focus {
        outline: none;
        border-color: var(--border-strong);
    }

    .contact-form select option {
        background-color: var(--surface);
        color: var(--fg);
    }

    .contact-form textarea {
        resize: vertical;
        min-height: 120px;
    }

    .info-title {
        margin-bottom: var(--space-10);
    }

    .info-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: var(--space-8);
    }

    .info-key {
        font-family: var(--font-display);
        font-size: var(--text-sm);
        font-weight: var(--font-semibold);
        color: var(--fg-muted);
        text-transform: uppercase;
        letter-spacing: 0.08em;
        margin-bottom: var(--space-1);
    }

    @media (max-width: 768px) {
        .contact-grid {
            grid-template-columns: 1fr;
        }
    }
</style>
