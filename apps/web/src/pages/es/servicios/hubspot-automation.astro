---
import Layout from "../../../layouts/Layout.astro";
import { ArrowRight } from "lucide-astro";
import CTABlock from "../../../components/CTABlock.astro";

const lang = "es";
const title =
    "HubSpot CRM y Automatización | Implementación, Workflows e Integraciones | Cacao & Avocado";
const description =
    "Implementación de HubSpot CRM, automatización de marketing e integraciones de sistemas. Shopify, Salesforce, Stripe y conexiones API personalizadas. 50+ implementaciones, 20 hrs/semana ahorradas.";
---

<Layout title={title} description={description} lang={lang}>
    <main>
        <!-- Hero -->
        <section class="ds-page-hero">
            <div class="ds-container">
                <h1 class="ds-h1">HubSpot CRM y Automatización que Impulsa Crecimiento</h1>
                <p class="ds-body-lg">
                    Implementamos HubSpot CRM, construimos workflows de
                    automatización de marketing e integramos todo tu stack de
                    crecimiento. Nuestras automatizaciones ahorran a los equipos
                    más de 20 horas semanales e incrementan la precisión de
                    atribución de marketing en un 60%.
                </p>
                <p class="ds-body metrics-line">
                    50+ implementaciones · 200+ automatizaciones desplegadas · 20 hrs/semana ahorradas
                </p>
                <div class="ds-btn-group">
                    <a href={`/${lang}/contacto`} class="ds-btn ds-btn--primary">
                        Agendar Consulta HubSpot
                        <span class="ds-btn__dot"><ArrowRight size={12} strokeWidth={2} /></span>
                    </a>
                    <a href={`/${lang}/proyectos`} class="ds-btn ds-btn--outline">
                        Ver Trabajo de Integraciones
                        <span class="ds-btn__dot"><ArrowRight size={12} strokeWidth={2} /></span>
                    </a>
                </div>
            </div>
        </section>

        <!-- Resumen -->
        <section class="ds-section ds-section--subtle ds-section--border-b">
            <div class="ds-container">
                <span class="ds-label">Qué Construimos</span>
                <h2 class="ds-h2 section-title">
                    Tres servicios HubSpot centrales: implementación de CRM, automatización de marketing e integraciones de sistemas.
                </h2>
            </div>
        </section>

        <!-- Servicio 1: CRM -->
        <section class="ds-section ds-section--border-b">
            <div class="ds-container service-block">
                <h3 class="ds-h3 service-title">Implementación y Migración de HubSpot CRM</h3>
                <div class="service-body">
                    <div class="service-subsection">
                        <p class="subsection-label">Qué es</p>
                        <p class="ds-body">
                            Configuración completa de HubSpot CRM desde cero o
                            migración desde Salesforce, Pipedrive o sistemas
                            personalizados. Configuramos pipelines, propiedades
                            personalizadas, etapas de negociación y dashboards
                            de reportes. Obtienes un CRM adaptado a tu proceso
                            de ventas, no al predeterminado de HubSpot.
                        </p>
                    </div>
                    <div class="service-subsection">
                        <p class="subsection-label">Ideal para</p>
                        <ul class="ds-check-list">
                            <li>Empresas que pasan de hojas de cálculo a un CRM real</li>
                            <li>Equipos que migran desde Salesforce, Pipedrive o sistemas legacy</li>
                            <li>Negocios que necesitan pipelines de negociación personalizados (B2B, SaaS, agencias)</li>
                            <li>Equipos de ventas que quieren mejores reportes y proyecciones</li>
                        </ul>
                    </div>
                    <div class="ds-pill-group">
                        <span class="ds-pill">HubSpot CRM</span>
                        <span class="ds-pill">HubSpot API</span>
                        <span class="ds-pill">Data Migration Tools</span>
                        <span class="ds-pill">Salesforce API</span>
                    </div>
                    <div class="pricing-box">
                        <div class="pricing-item">
                            <span class="pricing-label">Timeline</span>
                            <span class="pricing-value">4–6 semanas</span>
                        </div>
                        <div class="pricing-item">
                            <span class="pricing-label">Inversión</span>
                            <span class="pricing-value">$8,000 – $20,000</span>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Servicio 2: Automatización -->
        <section class="ds-section ds-section--subtle ds-section--border-b">
            <div class="ds-container service-block">
                <h3 class="ds-h3 service-title">Automatización de Marketing y Workflows</h3>
                <div class="service-body">
                    <div class="service-subsection">
                        <p class="subsection-label">Qué es</p>
                        <p class="ds-body">
                            Campañas automatizadas de lead nurture, lead
                            scoring, secuencias de email y disparadores
                            conductuales. Construimos workflows que califican
                            leads, los enrutan a ventas y rastrean la
                            atribución. Integrado con tu CRM, formularios del
                            sitio web y plataformas de anuncios para visibilidad
                            completa del embudo.
                        </p>
                    </div>
                    <div class="service-subsection">
                        <p class="subsection-label">Ideal para</p>
                        <ul class="ds-check-list">
                            <li>Equipos de marketing que califican leads manualmente</li>
                            <li>Empresas con ciclos de venta largos (B2B, SaaS, alto valor)</li>
                            <li>Marcas que ejecutan campañas multicanal (email, anuncios, webinars)</li>
                            <li>Equipos que quieren mejor atribución (¿qué campañas generan ingresos?)</li>
                        </ul>
                    </div>
                    <div class="pricing-box">
                        <div class="pricing-item">
                            <span class="pricing-label">Timeline</span>
                            <span class="pricing-value">5–8 semanas</span>
                        </div>
                        <div class="pricing-item">
                            <span class="pricing-label">Inversión</span>
                            <span class="pricing-value">$10,000 – $25,000</span>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Servicio 3: Integraciones -->
        <section class="ds-section ds-section--border-b">
            <div class="ds-container service-block">
                <h3 class="ds-h3 service-title">Integraciones de Sistemas con HubSpot</h3>
                <div class="service-body">
                    <div class="service-subsection">
                        <p class="subsection-label">Qué es</p>
                        <p class="ds-body">
                            Conecta HubSpot a todo tu stack tecnológico:
                            Shopify, Salesforce, procesadores de pago (Stripe),
                            soporte al cliente (Zendesk) y APIs personalizadas.
                            Sincronización bidireccional de contactos, pedidos y
                            actividades. Construimos integraciones personalizadas
                            cuando las apps nativas no existen o no satisfacen
                            tus necesidades.
                        </p>
                    </div>
                    <div class="service-subsection">
                        <p class="subsection-label">Ideal para</p>
                        <ul class="ds-check-list">
                            <li>Marcas e-commerce que sincronizan pedidos Shopify con HubSpot</li>
                            <li>Empresas que usan HubSpot + Salesforce (necesitan sincronización bidireccional)</li>
                            <li>Productos SaaS que rastrean el uso del producto en HubSpot</li>
                            <li>Equipos con sistemas personalizados que necesitan integración con HubSpot</li>
                        </ul>
                    </div>
                    <div class="ds-pill-group">
                        <span class="ds-pill">HubSpot API</span>
                        <span class="ds-pill">Shopify API</span>
                        <span class="ds-pill">Salesforce API</span>
                        <span class="ds-pill">Stripe API</span>
                        <span class="ds-pill">Node.js</span>
                    </div>
                    <div class="pricing-box">
                        <div class="pricing-item">
                            <span class="pricing-label">Timeline</span>
                            <span class="pricing-value">3–6 semanas</span>
                        </div>
                        <div class="pricing-item">
                            <span class="pricing-label">Inversión</span>
                            <span class="pricing-value">$5,000 – $18,000</span>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <CTABlock
            title="Auditemos Tu Configuración de HubSpot"
            subtitle="¿Ya usas HubSpot? Auditaremos tu configuración actual e identificaremos victorias rápidas. ¿Considerando HubSpot? Evaluaremos si es la opción correcta y proporcionaremos una hoja de ruta de implementación."
            primaryButtonText="Agendar Auditoría Gratuita"
            primaryButtonLink={`/${lang}/contacto`}
            secondaryButtonText="Cuéntanos sobre Tu Stack"
            secondaryButtonLink={`/${lang}/contacto`}
        />
    </main>
</Layout>

<style>
    .metrics-line {
        color: var(--fg-muted);
        margin-bottom: var(--space-8);
    }

    .section-title {
        margin-bottom: 0;
        font-weight: var(--font-normal);
        color: var(--fg-muted);
        font-size: var(--text-lg);
        font-family: var(--font-body);
        max-width: 700px;
    }

    .service-block {
        max-width: 900px;
    }

    .service-title {
        margin-bottom: var(--space-8);
        padding-bottom: var(--space-5);
        border-bottom: 1px solid var(--border);
    }

    .service-body {
        display: flex;
        flex-direction: column;
        gap: var(--space-6);
    }

    .service-subsection {
        display: flex;
        flex-direction: column;
        gap: var(--space-3);
    }

    .subsection-label {
        font-family: var(--font-display);
        font-size: var(--text-sm);
        font-weight: var(--font-semibold);
        color: var(--fg-muted);
        text-transform: uppercase;
        letter-spacing: 0.08em;
    }

    .pricing-box {
        display: flex;
        gap: var(--space-10);
        padding: var(--space-5) var(--space-6);
        border: 1px solid var(--border);
        border-left: 3px solid var(--accent);
        border-radius: var(--radius-sm);
        background-color: var(--surface);
        margin-top: var(--space-2);
    }

    .pricing-item {
        display: flex;
        flex-direction: column;
        gap: var(--space-1);
    }

    .pricing-label {
        font-size: var(--text-xs);
        color: var(--fg-muted);
        text-transform: uppercase;
        letter-spacing: 0.08em;
        font-family: var(--font-display);
    }

    .pricing-value {
        font-family: var(--font-display);
        font-size: var(--text-xl);
        font-weight: var(--font-bold);
        color: var(--fg);
    }

    @media (max-width: 768px) {
        .pricing-box {
            flex-direction: column;
            gap: var(--space-5);
        }
    }
</style>
