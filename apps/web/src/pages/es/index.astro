---
import Layout from "../../layouts/Layout.astro";
import Hero from "../../components/Hero.astro";
import Services from "../../components/Services.astro";
import ProjectsHome from "../../components/ProjectsHome.astro";
import MetricsSection from "../../components/MetricsSection.astro";
import TechStack from "../../components/TechStack.astro";
import CTABlock from "../../components/CTABlock.astro";
import { ui } from "../../i18n/ui";

const lang = "es";
const t = ui[lang];

const title =
    "Cacao & Avocado | Agencia de Desarrollo Shopify y Web | Colombia y EE.UU.";
const description =
    "Agencia premium de desarrollo e-commerce y web con base en Medellín. Construimos tiendas Shopify, sitios corporativos e integraciones HubSpot para marcas en Colombia y Estados Unidos.";
---

<Layout title={title} description={description} lang={lang}>
    <main>
        <Hero
            title={`Bienvenido a la Autenticidad del <span class="accent">Trópico</span>`}
            subtitle="Construimos tiendas Shopify, sitios web de alto rendimiento e integraciones HubSpot para marcas ambiciosas en Colombia y Estados Unidos. Ingeniería senior, sin atajos, sin relleno."
            ctaPrimary="Solicitar Cotización"
            ctaPrimaryHref={`/${lang}/contacto`}
            ctaSecondary="Ver Servicios"
            ctaSecondaryHref="#servicios"
            lang={lang}
        />
        <Services
            title={t["services.title"]}
            shopifyTitle="Desarrollo E-commerce"
            shopifyDesc="Tiendas Shopify y WooCommerce construidas para vender. Desde desarrollo de temas custom y optimización de checkout hasta arquitectura headless — creamos experiencias de e-commerce que generan ingresos, no solo visitas."
            hubspotTitle="HubSpot y Automatización"
            hubspotDesc="Desarrollo HubSpot CMS, configuración de CRM y automatización de marketing que conecta tu sitio web con tu pipeline de ventas. Construimos la parte técnica para que tu equipo pueda enfocarse en cerrar negocios."
            webTitle="Desarrollo Web y CMS"
            webDesc="Sitios corporativos, portafolios creativos y landing pages construidos para rendir. Rápidos, limpios y fáciles de manejar para tu equipo — ya seas una firma de arquitectura en Medellín o una startup en Miami."
            lang={lang}
        />
        <ProjectsHome
            title={t["projects.title"]}
            intro="Algunos de nuestros trabajos recientes en Shopify, desarrollo web y HubSpot."
            viewAll={t["projects.viewAll"]}
            viewProject={t["projects.viewProject"]}
            empty={t["projects.empty"]}
            lang={lang}
        />
        <MetricsSection
            title="Por los Números"
            metric1Number="11+"
            metric1Label="Años de Experiencia en Ingeniería"
            metric2Number="20+"
            metric2Label="Proyectos Entregados en Colombia y EE.UU."
            metric3Number="85+"
            metric3Label="Puntuación Lighthouse Promedio"
            metric4Number="2"
            metric4Label="Mercados. Un Solo Estándar de Calidad."
        />
        <TechStack
            title="Tecnologías Con Las Que Trabajamos"
            subtitle="Nuestro enfoque multi-especialidad significa que podemos arquitectar soluciones completas, no solo piezas. Estas son las plataformas y frameworks que desplegamos diariamente."
        />
        <CTABlock
            title="¿Listo para Construir Algo que Realmente Funcione?"
            subtitle="Cuéntanos sobre tu proyecto. Respondemos en 24 horas con un enfoque técnico y un presupuesto claro. Sin propuestas vagas, sin sorpresas en la factura."
            primaryButtonText="Iniciar un Proyecto"
            primaryButtonLink={`/${lang}/contacto`}
        />
    </main>
</Layout>
